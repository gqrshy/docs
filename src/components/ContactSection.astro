---
// Contact section - Dark mode design
---

<section id="contact" class="contact-section">
	<div class="contact-wrapper">
		<!-- Header -->
		<div class="contact-header">
			<h2 class="contact-title">
				<span data-i18n="contactTitle">Get in touch</span>
			</h2>
			<p class="contact-subtitle" data-i18n="contactSubtitle">
				Want to collaborate or have questions?<br />
				Let me know and <span class="highlight">I'll reply as soon as I can</span>!
			</p>
			<p class="contact-note" data-i18n="contactNote">
				Please refrain from sending spam or unrelated inquiries.
			</p>
		</div>

		<!-- Form -->
		<form class="contact-form" action="https://formsubmit.co/gashistudios.llc@gmail.com" method="POST">
			<!-- Honeypot -->
			<input type="text" name="_honey" style="display:none">
			<!-- Disable captcha -->
			<input type="hidden" name="_captcha" value="false">
			<!-- Success redirect -->
			<input type="hidden" name="_next" value="https://gashistudios.site/?sent=true">

			<div class="form-row">
				<input type="email" name="email" required placeholder="Email" />
				<input type="text" name="name" required placeholder="Name" />
			</div>
			<textarea name="message" required placeholder="Type in a short message!" rows="5"></textarea>
			<button type="submit" class="submit-btn">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
					<polyline points="20,6 9,17 4,12"/>
				</svg>
				<span data-i18n="contactSubmit">submit</span>
			</button>
		</form>
	</div>
</section>

<script is:inline>
(function() {
	const translations = {
		en: {
			contactTitle: "Get in touch",
			contactSubtitle: "Want to collaborate or have questions?<br />Let me know and <span class=\"highlight\">I'll reply as soon as I can</span>!",
			contactNote: "Please refrain from sending spam or unrelated inquiries.",
			contactSubmit: "submit"
		},
		ja: {
			contactTitle: "お問い合わせ",
			contactSubtitle: "コラボや質問がありますか？<br /><span class=\"highlight\">できるだけ早く返信します</span>！",
			contactNote: "スパムや無関係なお問い合わせはご遠慮ください。",
			contactSubmit: "送信"
		}
	};

	function applyContactTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.contact-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) {
				el.innerHTML = t[key];
			}
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyContactTranslations(lang);
	}

	window.addEventListener('langChange', (e) => {
		applyContactTranslations(e.detail.lang);
	});

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style>
.contact-section {
	position: relative;
	padding: 5rem 2rem 6rem;
	background: var(--color-bg-alt);
}

/* Subtle gradient */
.contact-section::before {
	content: '';
	position: absolute;
	bottom: 0;
	left: 0;
	right: 0;
	height: 400px;
	background: radial-gradient(ellipse at 50% 100%, rgba(139, 92, 246, 0.08) 0%, transparent 70%);
	pointer-events: none;
}

/* Wrapper */
.contact-wrapper {
	position: relative;
	max-width: 800px;
	margin: 0 auto;
	z-index: 1;
}

/* Header */
.contact-header {
	text-align: center;
	margin-bottom: 2rem;
}

.contact-title {
	font-size: 3rem;
	font-weight: 700;
	color: var(--color-text);
	margin: 0 0 16px;
	line-height: 1.1;
}

.contact-subtitle {
	font-size: 1.1rem;
	color: var(--color-text-muted);
	margin: 0 0 8px;
	line-height: 1.7;
}

.highlight {
	color: var(--color-primary);
}

.contact-note {
	font-size: 0.9rem;
	color: var(--color-text-muted);
	margin: 0;
	opacity: 0.7;
}

/* Form */
.contact-form {
	display: flex;
	flex-direction: column;
	gap: 20px;
}

.form-row {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 20px;
}

.contact-form input[type="email"],
.contact-form input[type="text"],
.contact-form textarea {
	width: 100%;
	padding: 16px 20px;
	border: 1px solid var(--color-border);
	border-radius: 8px;
	background: var(--color-bg-card);
	font-size: 1rem;
	font-family: inherit;
	color: var(--color-text);
	transition: all 0.2s ease;
}

.contact-form input::placeholder,
.contact-form textarea::placeholder {
	color: var(--color-text-muted);
}

.contact-form input:focus,
.contact-form textarea:focus {
	outline: none;
	border-color: var(--color-primary);
	box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
}

.contact-form textarea {
	resize: vertical;
	min-height: 140px;
}

.submit-btn {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	gap: 10px;
	padding: 14px 40px;
	background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%);
	color: #fff;
	border: none;
	border-radius: 8px;
	font-size: 1rem;
	font-weight: 600;
	font-family: inherit;
	cursor: pointer;
	transition: all 0.2s ease;
	align-self: center;
	margin-top: 8px;
	box-shadow: 0 4px 20px rgba(139, 92, 246, 0.3);
}

.submit-btn:hover {
	box-shadow: 0 6px 30px rgba(139, 92, 246, 0.5);
	transform: translateY(-2px);
}

.submit-btn svg {
	flex-shrink: 0;
}

/* Responsive */
@media (max-width: 768px) {
	.contact-header {
		text-align: center;
	}

	.contact-title {
		font-size: 2.5rem;
	}

	.contact-form input[type="email"],
	.contact-form input[type="text"],
	.contact-form textarea {
		padding: 14px 16px;
		font-size: 1rem;
	}

	.form-row {
		grid-template-columns: 1fr;
	}
}

@media (max-width: 600px) {
	.contact-section {
		padding: 3rem 1rem 4rem;
	}

	.contact-title {
		font-size: 2rem;
	}

	.contact-subtitle {
		font-size: 1rem;
	}

	.submit-btn {
		padding: 14px 32px;
		font-size: 0.95rem;
	}
}
</style>
