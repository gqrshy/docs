---
// Contact section - B&W window card form, grid bg, outlined submit
---

<section id="contact" class="contact-section">

	<div class="contact-wrapper">
		<!-- Header -->
		<div class="contact-header">
			<h2 class="contact-title">
				<span data-i18n="contactTitle">Get in touch</span>
			</h2>
			<span class="title-underline" aria-hidden="true"></span>
			<p class="contact-subtitle" data-i18n="contactSubtitle">
				Want to collaborate or have questions?<br />
				Let me know and <span class="highlight">I'll reply as soon as I can</span>!
			</p>
			<p class="contact-note" data-i18n="contactNote">
				Please refrain from sending spam or unrelated inquiries.
			</p>
		</div>

		<!-- Success banner -->
		<div id="contact-success" class="success-banner" style="display: none;">
			<span class="success-icon">&#10003;</span>
			<span data-i18n="contactSuccess">Message sent!</span>
			<p data-i18n="contactSuccessText">Thanks for reaching out. I'll get back to you soon.</p>
		</div>

		<!-- Form in window card -->
		<div class="window-card contact-form-card">
			<div class="window-titlebar">
				<span class="window-close"></span>
				<span class="window-title">contact.msg</span>
			</div>
			<div class="window-content">
				<form class="contact-form" action="https://formsubmit.co/gashistudios.llc@gmail.com" method="POST">
					<!-- Honeypot -->
					<input type="text" name="_honey" style="display:none">
					<!-- Disable captcha -->
					<input type="hidden" name="_captcha" value="false">
					<!-- Success redirect -->
					<input type="hidden" name="_next" value="https://gashistudios.site/?sent=true">

					<div class="form-row">
						<input type="email" name="email" required placeholder="Email" />
						<input type="text" name="name" required placeholder="Name" />
					</div>
					<textarea name="message" required placeholder="Type in a short message!" rows="5"></textarea>
					<button type="submit" class="submit-btn">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
							<polyline points="20,6 9,17 4,12"/>
						</svg>
						<span data-i18n="contactSubmit">submit</span>
					</button>
				</form>
			</div>
		</div>
	</div>
</section>

<script is:inline>
(function() {
	const translations = {
		en: {
			contactTitle: "Get in touch",
			contactSubtitle: "Want to collaborate or have questions?<br />Let me know and <span class=\"highlight\">I'll reply as soon as I can</span>!",
			contactNote: "Please refrain from sending spam or unrelated inquiries.",
			contactSubmit: "submit",
			contactSuccess: "Message sent!",
			contactSuccessText: "Thanks for reaching out. I'll get back to you soon."
		},
		ja: {
			contactTitle: "お問い合わせ",
			contactSubtitle: "コラボや質問がありますか？<br /><span class=\"highlight\">できるだけ早く返信します</span>！",
			contactNote: "スパムや無関係なお問い合わせはご遠慮ください。",
			contactSubmit: "送信",
			contactSuccess: "メッセージ送信完了！",
			contactSuccessText: "お問い合わせありがとうございます。できるだけ早く返信します。"
		}
	};

	function applyContactTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.contact-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) {
				el.innerHTML = t[key];
			}
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyContactTranslations(lang);

		// Check for success state
		const params = new URLSearchParams(window.location.search);
		if (params.get('sent') === 'true') {
			const banner = document.getElementById('contact-success');
			if (banner) {
				banner.style.display = 'block';
				banner.classList.add('animate-in');
			}
		}
	}

	window.addEventListener('langChange', (e) => {
		applyContactTranslations(e.detail.lang);
	});

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style>
.contact-section {
	position: relative;
	padding: 5rem 2rem 6rem;
	background: var(--color-bg-alt);
	overflow: hidden;
}

/* Grid background removed */

/* Wrapper */
.contact-wrapper {
	position: relative;
	max-width: 800px;
	margin: 0 auto;
	z-index: 1;
}

/* Header */
.contact-header {
	text-align: center;
	margin-bottom: 2rem;
}

.contact-title {
	font-size: 3rem;
	font-weight: 700;
	color: var(--color-text);
	margin: 0 0 8px;
	line-height: 1.1;
	font-family: 'IBM Plex Mono', monospace;
}

/* Straight underline */
.title-underline {
	display: block;
	width: 80px;
	height: 2px;
	background: rgba(255, 255, 255, 0.3);
	border-radius: 1px;
	margin: 0 auto 16px;
}

.contact-subtitle {
	font-size: 1.1rem;
	color: var(--color-text-muted);
	margin: 0 0 8px;
	line-height: 1.7;
}

.highlight {
	color: #ffffff;
}

.contact-note {
	font-size: 0.9rem;
	color: var(--color-text-muted);
	margin: 0;
	opacity: 0.7;
}

/* Success banner */
.success-banner {
	text-align: center;
	padding: 1.25rem;
	background: rgba(255, 255, 255, 0.05);
	border: 1px solid rgba(255, 255, 255, 0.2);
	border-radius: 12px;
	margin-bottom: 2rem;
	color: #ffffff;
	font-weight: 600;
	font-family: 'IBM Plex Mono', monospace;
}

.success-banner.animate-in {
	animation: bounceIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.success-icon {
	font-size: 1.25rem;
	margin-right: 0.5rem;
}

.success-banner p {
	color: var(--color-text-muted);
	font-weight: 400;
	font-size: 0.9rem;
	margin: 0.5rem 0 0;
}

/* Form window card */
.contact-form-card {
	background: var(--color-surface);
}

.contact-form-card:hover {
	border-color: rgba(255, 255, 255, 0.25);
}

/* Form */
.contact-form {
	display: flex;
	flex-direction: column;
	gap: 20px;
}

.form-row {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 20px;
}

.contact-form input[type="email"],
.contact-form input[type="text"],
.contact-form textarea {
	width: 100%;
	padding: 16px 20px;
	border: 1px solid var(--color-border);
	border-radius: 8px;
	background: rgba(255, 255, 255, 0.03);
	font-size: 1rem;
	font-family: 'IBM Plex Mono', monospace;
	color: var(--color-text);
	transition: all 0.2s ease;
}

.contact-form input::placeholder,
.contact-form textarea::placeholder {
	color: var(--color-text-muted);
	opacity: 0.5;
}

/* White border on focus */
.contact-form input:focus,
.contact-form textarea:focus {
	outline: none;
	border-color: rgba(255, 255, 255, 0.4);
	box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.05);
	background: rgba(255, 255, 255, 0.05);
}

.contact-form textarea {
	resize: vertical;
	min-height: 140px;
}

/* Submit button - white outlined */
.submit-btn {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	gap: 10px;
	padding: 14px 40px;
	background: transparent;
	color: #ffffff;
	border: 1px solid rgba(255, 255, 255, 0.3);
	border-radius: 8px;
	font-size: 1rem;
	font-weight: 600;
	font-family: 'IBM Plex Mono', monospace;
	cursor: pointer;
	transition: all 0.2s ease;
	align-self: center;
	margin-top: 8px;
}

.submit-btn:hover {
	background: #ffffff;
	color: #000000;
	border-color: #ffffff;
	transform: translateY(-2px);
}

.submit-btn svg {
	flex-shrink: 0;
}

/* Responsive */
@media (max-width: 768px) {
	.contact-header {
		text-align: center;
	}

	.contact-title {
		font-size: 2.5rem;
	}

	.contact-form input[type="email"],
	.contact-form input[type="text"],
	.contact-form textarea {
		padding: 14px 16px;
		font-size: 1rem;
	}

	.form-row {
		grid-template-columns: 1fr;
	}
}

@media (max-width: 600px) {
	.contact-section {
		padding: 3rem 1rem 4rem;
	}

	.contact-title {
		font-size: 2rem;
	}

	.contact-subtitle {
		font-size: 1rem;
	}

	.submit-btn {
		padding: 14px 32px;
		font-size: 0.95rem;
	}
}
</style>
