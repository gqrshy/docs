---
// Footer — Phoenix-style: centered brand, copyright, link row, social icons
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-inner">
		<a href="/" class="footer-brand" aria-label="GashiStudios home">
			<img src="/gashistudios.png" alt="" class="footer-logo" />
			<span class="footer-brand-name">Gashi<br />Studios</span>
		</a>

		<p class="footer-copy">
			Copyright © {year} GashiStudios – All rights reserved<br />
			GashiStudios is not affiliated with Minecraft, Microsoft or Mojang AB
		</p>

		<nav class="footer-links" aria-label="Footer">
			<a href="/terms" data-i18n="footTerms">Terms</a>
			<a href="/docs/cobbleranked/" data-i18n="footDocs">Docs</a>
			<a href="/#contact" data-i18n="footSupport">Support</a>
			<a href="/#team" data-i18n="footAbout">About</a>
		</nav>

		<div class="footer-social">
			<a href="https://discord.gg/VVVvBTqqyP" target="_blank" rel="noopener noreferrer" aria-label="Discord">
				<i class="ph ph-discord-logo"></i>
			</a>
			<a href="https://x.com/Gashi85806256" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
				<i class="ph ph-x-logo"></i>
			</a>
			<a href="https://github.com/gqrshy" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
				<i class="ph ph-github-logo"></i>
			</a>
		</div>
	</div>
</footer>

<script is:inline>
(function() {
	const translations = {
		en: { footTerms: 'Terms', footDocs: 'Docs', footSupport: 'Support', footAbout: 'About' },
		ja: { footTerms: '利用規約', footDocs: 'ドキュメント', footSupport: 'サポート', footAbout: 'チーム' }
	};

	function apply(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.site-footer [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) el.textContent = t[key];
		});
	}
	window.addEventListener('langChange', (e) => apply(e.detail.lang));
	apply(window.GashiLang?.get() || 'en');
})();
</script>

<style>
.site-footer {
	background: var(--bg-base);
	border-top: 1px solid var(--border-subtle);
	padding: 3.5rem 2rem 3rem;
}

.footer-inner {
	max-width: 1100px;
	margin: 0 auto;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 1.5rem;
	text-align: center;
}

.footer-brand {
	display: flex;
	align-items: center;
	gap: 0.6rem;
	text-decoration: none;
}

.footer-logo {
	width: 40px;
	height: 40px;
	border-radius: 10px;
}

.footer-brand-name {
	font-family: var(--font-display);
	font-size: 0.9rem;
	font-weight: 700;
	line-height: 1.1;
	color: var(--text-primary);
	text-align: left;
}

.footer-copy {
	font-size: 0.82rem;
	color: var(--text-secondary);
	line-height: 1.7;
}

.footer-links {
	display: flex;
	gap: 2rem;
	flex-wrap: wrap;
	justify-content: center;
}

.footer-links a {
	color: var(--text-secondary);
	text-decoration: none;
	font-size: 0.9rem;
	font-weight: 500;
	transition: color 0.2s ease;
}

.footer-links a:hover { color: var(--text-primary); }

.footer-social {
	display: flex;
	gap: 1.25rem;
}

.footer-social a {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 38px;
	height: 38px;
	border-radius: 10px;
	color: var(--text-muted);
	font-size: 1.35rem;
	text-decoration: none;
	transition: color 0.2s ease, background 0.2s ease, transform var(--dur-base) var(--ease-bounce);
}

.footer-social a:hover {
	color: var(--text-primary);
	background: var(--purple-100);
	transform: translateY(-2px);
}

@media (max-width: 600px) {
	.site-footer { padding: 2.5rem 1.25rem; }
	.footer-links { gap: 1.25rem; }
}
</style>
