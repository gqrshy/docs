---
// Hero — Phoenix-style: bold copy left, character render right, purple glow
---

<section class="hero-section">
	<div class="hero-glow" aria-hidden="true"></div>

	<div class="hero-content">
		<div class="hero-text stagger-children">
			<span class="hero-label">// Minecraft mods &amp; server plugins</span>
			<h1 class="hero-title" data-i18n="heroTitle">
				Power Up Your<br />Minecraft Server
			</h1>
			<p class="hero-lead" data-i18n="heroLead">
				Developing Minecraft plugins since 2024, trusted by numerous public servers.
				We craft mods, Paper / Folia plugins, and Cobblemon ecosystem tools.
			</p>
			<div class="hero-buttons">
				<a href="#catalog" class="btn btn-primary">
					<span data-i18n="heroProducts">Browse All</span>
				</a>
				<a href="https://discord.gg/VVVvBTqqyP" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
						<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.36-.698.772-1.362 1.225-1.993a.076.076 0 0 0-.041-.107c-.636-.255-1.242-.568-1.872-.892a.077.077 0 0 1-.008-.128c.12-.09.246-.198.372-.292a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127c-.628.326-1.278.64-1.873.892a.077.077 0 0 0-.041.107c.448.693.907 1.361 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
					</svg>
					<span data-i18n="heroDiscord">Join Discord</span>
				</a>
			</div>
			<div class="hero-badges">
				<span class="badge badge-mod">Fabric</span>
				<span class="badge badge-mod">NeoForge</span>
				<span class="badge badge-plugin">Paper</span>
				<span class="badge badge-plugin">Folia</span>
				<span class="badge badge-lib">Cobblemon</span>
			</div>
		</div>

		<div class="hero-visual reveal-up">
			<img src="/character.png" alt="Gashi" class="hero-character" />
		</div>
	</div>

	<div class="hero-trusted reveal-up">
		<div class="trusted-label">
			<span class="trusted-title" data-i18n="trustedTitle">Trusted by the community</span>
			<span class="trusted-sub" data-i18n="trustedSub">Serving public Minecraft servers since 2024</span>
		</div>
		<ul class="trusted-items">
			<li><i class="ph ph-rocket-launch"></i> <span data-i18n="trustedSince">Since 2024</span></li>
			<li><i class="ph ph-globe-hemisphere-west"></i> <span data-i18n="trustedServers">Public servers worldwide</span></li>
			<li><i class="ph ph-stack"></i> <span data-i18n="trustedStack">Mods · Paper / Folia plugins</span></li>
			<li><i class="ph ph-chats-circle"></i> <span data-i18n="trustedDiscord">Active Discord support</span></li>
		</ul>
	</div>
</section>

<script is:inline>
(function() {
	const translations = {
		en: {
			heroTitle: "Transform Your<br />Minecraft Server<br />Like Never Before",
			heroLead: "Developing Minecraft plugins since 2024, trusted by numerous public servers. We craft mods, Paper / Folia plugins, and Cobblemon ecosystem tools to keep your players engaged.",
			heroProducts: "Browse All",
			heroDiscord: "Join Discord",
			trustedTitle: "Trusted by the community",
			trustedSub: "Serving public Minecraft servers since 2024",
			trustedSince: "Since 2024",
			trustedServers: "Public servers worldwide",
			trustedStack: "Mods · Paper / Folia plugins",
			trustedDiscord: "Active Discord support"
		},
		ja: {
			heroTitle: "Minecraftサーバーを、<br />もっと面白く。",
			heroLead: "2024年からMinecraftプラグイン開発を開始し、数多くのパブリックサーバーへ提供してきました。Mod、Paper / Foliaプラグイン、Cobblemonエコシステム向けツールを制作しています。",
			heroProducts: "プロダクトを見る",
			heroDiscord: "Discordに参加",
			trustedTitle: "コミュニティからの信頼",
			trustedSub: "2024年からパブリックサーバーへ提供",
			trustedSince: "2024年〜",
			trustedServers: "世界中のパブリックサーバー",
			trustedStack: "Mod · Paper / Foliaプラグイン",
			trustedDiscord: "Discordサポート",
		}
	};

	function applyHeroTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.hero-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) {
				el.innerHTML = t[key];
			}
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyHeroTranslations(lang);
	}

	window.addEventListener('langChange', (e) => {
		applyHeroTranslations(e.detail.lang);
	});

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style>
.hero-section {
	min-height: 92vh;
	background: var(--bg-base);
	display: flex;
	flex-direction: column;
	justify-content: center;
	padding: 56px 3rem 64px;
	position: relative;
	overflow: hidden;
}

/* Purple glow behind the character (static) */
.hero-glow {
	position: absolute;
	right: -5%;
	top: 20%;
	width: 55%;
	height: 70%;
	background: radial-gradient(ellipse 50% 50% at 60% 50%, rgba(139, 92, 246, 0.22), transparent 70%);
	pointer-events: none;
}

.hero-content {
	max-width: 1150px;
	margin: 0 auto;
	width: 100%;
	display: grid;
	grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
	gap: 3rem;
	align-items: center;
	position: relative;
	z-index: 1;
}

.hero-label {
	display: block;
	font-family: var(--font-mono);
	font-size: 0.8rem;
	font-weight: 500;
	color: var(--text-accent);
	letter-spacing: 0.14em;
	text-transform: uppercase;
	margin-bottom: 1.25rem;
}

.hero-title {
	font-family: var(--font-display);
	font-size: clamp(2.5rem, 5.5vw, 4.25rem);
	font-weight: 700;
	color: var(--text-primary);
	letter-spacing: -0.03em;
	line-height: 1.08;
	margin-bottom: 1.5rem;
}

.hero-lead {
	font-size: 1.05rem;
	color: var(--text-secondary);
	line-height: 1.85;
	max-width: 34rem;
	margin-bottom: 2rem;
}

.hero-buttons {
	display: flex;
	gap: 1rem;
	flex-wrap: wrap;
	margin-bottom: 2.25rem;
}

.hero-badges {
	display: flex;
	gap: 0.6rem;
	flex-wrap: wrap;
}

.hero-visual {
	display: flex;
	justify-content: center;
	align-items: flex-end;
}

.hero-character {
	max-height: 560px;
	width: auto;
	filter: drop-shadow(0 20px 50px rgba(139, 92, 246, 0.25));
}

/* ===== Trusted strip ===== */
.hero-trusted {
	width: 100%;
	max-width: 1150px;
	margin: 3.5rem auto 0;
	position: relative;
	z-index: 1;
	display: flex;
	align-items: center;
	gap: 2.5rem;
	flex-wrap: wrap;
	background: var(--bg-raised);
	border: 1px solid var(--border-subtle);
	border-radius: var(--radius-card);
	padding: 1.1rem 1.75rem;
}

.trusted-label {
	display: flex;
	flex-direction: column;
	gap: 0.1rem;
	flex-shrink: 0;
}

.trusted-title {
	font-family: var(--font-sans);
	font-size: 0.78rem;
	font-weight: 700;
	letter-spacing: 0.12em;
	text-transform: uppercase;
	color: var(--text-primary);
}

.trusted-sub {
	font-size: 0.72rem;
	color: var(--text-muted);
}

.trusted-items {
	display: flex;
	align-items: center;
	gap: 2rem;
	flex-wrap: wrap;
	list-style: none;
	margin-left: auto;
}

.trusted-items li {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	font-size: 0.82rem;
	font-weight: 500;
	color: var(--text-secondary);
	white-space: nowrap;
}

.trusted-items i {
	font-size: 1.15rem;
	color: var(--text-accent);
}

@media (max-width: 900px) {
	.hero-section {
		padding: 100px 1.5rem 50px;
		min-height: auto;
	}

	.hero-content {
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	.hero-visual {
		order: -1;
	}

	.hero-character {
		max-height: 300px;
	}

	.hero-glow {
		right: 0;
		top: 0;
		width: 100%;
		height: 50%;
	}
}
</style>
