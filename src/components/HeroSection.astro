<script is:inline>
(function() {
	const translations = {
		en: {
			heroHey: "Hey there!",
			heroName: "I'm Gashi!",
			heroBadge: "mod dev",
			heroBio: "Minecraft mod developer from Japan, creating tools for Cobblemon servers.<br />Passionate about clean code and fun gameplay.",
			heroDiscord: "Discord",
			heroDocs: "Docs"
		},
		ja: {
			heroHey: "こんにちは！",
			heroName: "がしです！",
			heroBadge: "mod開発者",
			heroBio: "日本のMinecraft Mod開発者。Cobblemonサーバー向けツールを制作。<br />クリーンなコードと楽しいゲームプレイを追求。",
			heroDiscord: "Discord",
			heroDocs: "ドキュメント"
		}
	};

	function applyHeroTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.hero-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) {
				el.innerHTML = t[key];
			}
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyHeroTranslations(lang);
	}

	window.addEventListener('langChange', (e) => {
		applyHeroTranslations(e.detail.lang);
	});

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style>
.hero-section {
	min-height: 100vh;
	background: var(--color-bg);
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	padding: 100px 60px 60px;
	position: relative;
	overflow: hidden;
}

/* Grid background removed - now using warped grid in layout */

.hero-content {
	position: relative;
	z-index: 1;
	max-width: 1100px;
	width: 100%;
	display: grid;
	grid-template-columns: 1fr auto;
	gap: 4rem;
	align-items: center;
}

.hero-text {
	padding-left: 2rem;
}

/* Title */
.hero-title {
	font-family: 'IBM Plex Mono', monospace;
	font-size: 3.5rem;
	font-weight: 700;
	color: #fff;
	line-height: 1.15;
	margin-bottom: 0.25rem;
}

.name-highlight {
	color: #fff;
}

.hero-badge {
	display: inline-block;
	border: 1px solid rgba(255, 255, 255, 0.3);
	color: var(--color-text-muted);
	padding: 0.15rem 0.6rem;
	border-radius: 4px;
	font-size: 0.35em;
	font-weight: 600;
	font-family: 'IBM Plex Mono', monospace;
	letter-spacing: 0.05em;
	vertical-align: middle;
	margin-left: 0.75rem;
}

/* Bio */
.bio {
	color: var(--color-text-muted);
	font-size: 1.1rem;
	line-height: 1.8;
	margin-top: 1.25rem;
	max-width: 520px;
	border-left: 2px solid rgba(255, 255, 255, 0.15);
	padding-left: 1rem;
}

/* Buttons — pill shape with hover inversion */
.hero-buttons {
	display: flex;
	gap: 1rem;
	margin-top: 2rem;
}

.btn {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	padding: 0.75rem 1.5rem;
	border-radius: 100vh;
	font-size: 0.9rem;
	font-weight: 600;
	font-family: 'IBM Plex Mono', monospace;
	text-decoration: none;
	transition: all 0.2s ease;
}

.btn-primary {
	background: transparent;
	color: #fff;
	border: solid 1px rgba(255, 255, 255, 0.3);
}

.btn-primary:hover {
	background: #fff;
	color: #000;
}

.btn-secondary {
	background: transparent;
	color: var(--color-text-muted);
	border: solid 1px rgba(255, 255, 255, 0.15);
}

.btn-secondary:hover {
	border-color: rgba(255, 255, 255, 0.4);
	color: #fff;
}

.btn-secondary svg {
	transition: transform 0.2s ease;
}

.btn-secondary:hover svg {
	transform: translateX(3px);
}

/* ===== Character image - multi-window composition ===== */

.hero-character-grid {
	position: relative;
	place-items: end center;
	width: 560px;
	height: 880px;
	flex-shrink: 0;
}

.char-window {
	position: absolute;
}

/* ---- Main window: plain image, no dialog wrapper ---- */
.char-window-main {
	width: 500px;
	z-index: 1;
	bottom: 0;
	left: 50%;
	translate: -50% 0;
}

/* Main img needs its own rules since no char-window-body parent */
.char-window-main img {
	display: block;
	width: 100%;
	height: 835px;
	object-fit: cover;
	object-position: center 30%;
}

/* ---- Sub-window body (shared) ---- */
.char-window-body {
	padding: 0;
	overflow: hidden;
}

.char-window-body img {
	display: block;
	width: 100%;
	object-fit: cover;
}

/* === Sub-window: Right eye zoom === */
/*
 * Cropping mechanism:
 *   The .char-window-body is a fixed 160x160 square with overflow:hidden.
 *   Inside, the img is position:absolute with a large width (zoom level).
 *   Adjust these to control what's visible:
 *
 *   width  = zoom level (600px ≈ 3x, 1200px ≈ 6x)
 *   top    = vertical pan  (negative = shift up, positive = shift down)
 *   left   = horizontal pan (negative = shift left, positive = shift right)
 *
 *   Visible area = (|left|, |top|) to (|left|+160, |top|+160) on the scaled image
 */
.char-window-eye {
	width: 160px;
	z-index: 3;
	top: 110px;
	right: 130px;
}

.char-window-eye .char-window-body {
	height: 160px;
	position: relative;
	overflow: hidden;
}

.char-window-eye .char-window-body img {
	position: absolute;
	max-width: none;
	width: 600px;
	top: -150px;
	left: -300px;
}

/* === Sub-window: Gengar zoom === */
.char-window-hand {
	width: 160px;
	z-index: 2;
	top: 320px;
	left: 200px;
}

.char-window-hand .char-window-body {
	height: 160px;
	position: relative;
	overflow: hidden;
}

.char-window-hand .char-window-body img {
	position: absolute;
	max-width: none;
	width: 600px;
	top: -370px;
	left: -210px;
}

/* Stagger entrance animation */
@keyframes charWindowIn {
	from { opacity: 0; transform: translateY(20px) scale(0.95); }
	to { opacity: 1; transform: translateY(0) scale(1); }
}

.char-window-main { animation: charWindowIn 0.6s ease 0.1s both; }
.char-window-eye { animation: charWindowIn 0.6s ease 0.3s both; }
.char-window-hand { animation: charWindowIn 0.6s ease 0.5s both; }

/* Disable window-card hover on character sub-windows */
.char-window.window-card:hover {
	transform: none;
	border-color: rgba(255, 255, 255, 0.12);
	box-shadow: none;
}

/* Social sidebar - desktop */
.social-sidebar {
	position: fixed;
	left: 1.5rem;
	top: 50%;
	transform: translateY(-50%);
	display: flex;
	flex-direction: column;
	gap: 0.75rem;
	z-index: 10;
}

.social-link {
	width: 40px;
	height: 40px;
	border-radius: 2px;
	border: 1px solid rgba(255, 255, 255, 0.08);
	background: transparent;
	display: flex;
	align-items: center;
	justify-content: center;
	color: var(--color-text-muted);
	transition: all 0.2s ease;
}

.social-link:hover {
	background: rgba(255, 255, 255, 0.08);
	color: #fff;
	border-color: rgba(255, 255, 255, 0.2);
}

/* Social bar - mobile */
.social-mobile {
	display: none;
	justify-content: center;
	gap: 0.75rem;
	margin-top: 2rem;
	position: relative;
	z-index: 1;
}

/* Scroll indicator */
.scroll-indicator {
	position: absolute;
	bottom: 5rem;
	left: 50%;
	transform: translateX(-50%);
	z-index: 1;
}

.scroll-chevron {
	display: block;
	width: 12px;
	height: 12px;
	border-right: 2px solid rgba(255, 255, 255, 0.3);
	border-bottom: 2px solid rgba(255, 255, 255, 0.3);
	transform: rotate(45deg);
	animation: scrollBounce 2s ease-in-out infinite;
}

/* Responsive */
@media (max-width: 900px) {
	.hero-content {
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	.hero-character-grid {
		width: 260px;
		justify-self: center;
		order: -1;
	}
}

@media (max-width: 768px) {
	.hero-section {
		padding: 80px 1.5rem 60px;
		align-items: flex-start;
	}

	.hero-text {
		padding-left: 0;
		text-align: center;
		width: 100%;
	}

	.hero-title {
		font-size: 2.5rem;
	}

	.bio {
		border-left: none;
		padding-left: 0;
		text-align: center;
		max-width: 100%;
	}

	.hero-buttons {
		justify-content: center;
	}

	.social-sidebar {
		display: none;
	}

	.social-mobile {
		display: flex;
	}

	.hero-badge {
		display: none;
	}
}

@media (max-width: 480px) {
	.hero-title {
		font-size: 2rem;
	}

	.hero-character-grid {
		width: 200px;
	}

	.hero-buttons {
		flex-direction: column;
		width: 100%;
	}

	.btn {
		justify-content: center;
	}
}
</style>
