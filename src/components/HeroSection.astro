				</svg>
			</a>
		</div>
	</div>
</section>

<script is:inline>
(function() {
	const translations = {
		en: {
			greeting: "Hey there!",
			bio: "AKA Gqrshy! I'm a Minecraft Mod Developer from Japan!",
			joinDiscord: "join discord!",
			viewDocs: "see my mods!"
		},
		ja: {
			greeting: "こんにちは！",
			bio: "Gqrshyです！日本のMinecraft Mod開発者です！",
			joinDiscord: "discordに参加！",
			viewDocs: "Modを見る！"
		}
	};

	function applyHeroTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.hero-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) el.innerHTML = t[key];
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyHeroTranslations(lang);
	}

	window.addEventListener('langChange', (e) => applyHeroTranslations(e.detail.lang));
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style>
.hero-section {
	min-height: 100vh;
	background: var(--color-bg);
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	padding: 100px 60px 60px;
}

.hero-content {
	width: 100%;
	max-width: 800px;
	text-align: center;
	animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
	from {
		opacity: 0;
		transform: translateY(30px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

.hero-text {
	animation: fadeInUp 0.6s ease-out;
}

.title {
	margin: 0 0 24px;
}

.title-line-1,
.title-line-2 {
	display: block;
	font-weight: 700;
	color: var(--color-text);
	line-height: 1.1;
}

.title-line-1 {
	font-size: clamp(2rem, 4vw, 4rem);
	margin-bottom: 8px;
}

.title-line-2 {
	font-size: clamp(2.5rem, 5vw, 5rem);
}

.name-highlight {
	color: var(--color-primary);
}

.bio {
	font-size: 1.1rem;
	line-height: 1.7;
	color: var(--color-text-muted);
	margin: 0 0 32px;
	font-weight: 500;
}

/* Buttons */
.hero-buttons {
	display: flex;
	gap: 16px;
	flex-wrap: wrap;
	justify-content: center;
}

.btn {
	display: inline-flex;
	align-items: center;
	gap: 10px;
	padding: 14px 28px;
	border-radius: 8px;
	font-weight: 600;
	font-size: 1rem;
	text-decoration: none;
	transition: all 0.2s ease;
	border: none;
}

.btn svg {
	width: 18px;
	height: 18px;
	flex-shrink: 0;
}

.btn-primary {
	background: var(--color-primary);
	color: #fff;
}

.btn-primary:hover {
	background: var(--color-primary-light);
	transform: translateY(-2px);
}

.btn-secondary {
	background: transparent;
	color: var(--color-text);
	border: 1px solid var(--color-border);
}

.btn-secondary:hover {
	background: rgba(255, 255, 255, 0.05);
	border-color: var(--color-primary);
	color: var(--color-primary);
}

/* Social Bar */
.social-bar {
	display: flex;
	justify-content: center;
	align-items: center;
	gap: 12px;
	margin-top: 60px;
	animation: fadeInUp 0.6s ease-out 0.2s backwards;
}

.social-group {
	display: flex;
	gap: 10px;
}

.social-divider {
	width: 1px;
	height: 28px;
	background: var(--color-border);
	margin: 0 6px;
}

.social-link {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 46px;
	height: 46px;
	border-radius: 50%;
	background: var(--color-bg-card);
	color: var(--color-text-muted);
	transition: all 0.2s ease;
}

.social-link:hover {
	transform: translateY(-2px);
}

.social-link svg,
.social-link img {
	width: 20px;
	height: 20px;
	flex-shrink: 0;
	opacity: 0.7;
	transition: opacity 0.2s ease;
}

.social-link:hover svg,
.social-link:hover img {
	opacity: 1;
}

.social-link.github:hover { background: #333; color: #fff; }
.social-link.modrinth:hover { background: #1bd96a; color: #fff; }
.social-link.curseforge:hover { background: #f16436; color: #fff; }
.social-link.polymart:hover { background: #00b894; color: #fff; }
.social-link.youtube:hover { background: #ff0000; color: #fff; }
.social-link.x:hover { background: #000; color: #fff; }

/* Responsive */
@media (max-width: 768px) {
	.hero-section {
		padding: 80px 20px 40px;
	}

	.hero-content {
		padding: 0 1rem;
	}

	.bio {
		font-size: 1rem;
	}

	.social-bar {
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 40px;
	}

	.social-group {
		flex-wrap: wrap;
		justify-content: center;
		gap: 8px;
	}

	.social-divider {
		display: none;
	}

	.social-link {
		width: 40px;
		height: 40px;
	}

	.social-link svg,
	.social-link img {
		width: 18px;
		height: 18px;
	}

	.hero-buttons {
		flex-direction: column;
		align-items: center;
	}

	.btn {
		width: 100%;
		max-width: 240px;
		justify-content: center;
	}
}
</style>
