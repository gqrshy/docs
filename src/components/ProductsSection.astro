---
// Products section - B&W window cards
---

<section id="products" class="products-section">
	<div class="products-container">
		<div class="products-header">
			<h2 class="products-title" data-i18n="productsTitle">Products</h2>
			<p class="products-subtitle" data-i18n="productsSubtitle">Tools and libraries for Cobblemon servers</p>
		</div>

		<div class="products-grid">
			<a href="/docs/cobbleranked/" class="product-card window-card featured">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title">cobbleranked.cfg</span>
				</div>
				<div class="window-content">
					<div class="product-info">
						<div class="product-header">
							<h3 class="product-name">CobbleRanked</h3>
							<span class="product-tag featured-tag">Featured</span>
						</div>
						<p class="product-desc" data-i18n="productRankedDesc">
							Competitive Pokemon battle system with ELO ranking, tiers, and leaderboards for Cobblemon servers.
						</p>
					</div>
				</div>
			</a>

			<a href="/docs/gashilibs/" class="product-card window-card">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title">gashilibs.jar</span>
				</div>
				<div class="window-content">
					<div class="product-info">
						<div class="product-header">
							<h3 class="product-name">GashiLibs</h3>
							<span class="product-tag">Library</span>
						</div>
						<p class="product-desc" data-i18n="productLibsDesc">
							Shared utility library for Cobblemon addons. Database, UI, and common tools.
						</p>
					</div>
				</div>
			</a>

			<a href="/docs/maillib/" class="product-card window-card">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title">maillib.jar</span>
				</div>
				<div class="window-content">
					<div class="product-info">
						<div class="product-header">
							<h3 class="product-name">MailLib</h3>
							<span class="product-tag">Library</span>
						</div>
						<p class="product-desc" data-i18n="productMailDesc">
							In-game mail system library. Send, receive, and manage mail between players.
						</p>
					</div>
				</div>
			</a>
		</div>
	</div>
</section>

<script is:inline>
(function() {
	const translations = {
		en: {
			productsTitle: "Products",
			productsSubtitle: "Tools and libraries for Cobblemon servers",
			productRankedDesc: "Competitive Pokemon battle system with ELO ranking, tiers, and leaderboards for Cobblemon servers.",
			productLibsDesc: "Shared utility library for Cobblemon addons. Database, UI, and common tools.",
			productMailDesc: "In-game mail system library. Send, receive, and manage mail between players."
		},
		ja: {
			productsTitle: "プロダクト",
			productsSubtitle: "Cobblemonサーバー向けのツールとライブラリ",
			productRankedDesc: "ELOランキング、ティア、リーダーボードを備えたCobblemon向け競争型ポケモンバトルシステム。",
			productLibsDesc: "Cobblemonアドオン向けの共有ユーティリティライブラリ。データベース、UI、共通ツール。",
			productMailDesc: "ゲーム内メールシステムライブラリ。プレイヤー間でメールの送受信と管理。"
		}
	};

	function applyProductsTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.products-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) {
				el.innerHTML = t[key];
			}
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyProductsTranslations(lang);
	}

	window.addEventListener('langChange', (e) => {
		applyProductsTranslations(e.detail.lang);
	});

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style>
.products-section {
	padding: 5rem 2rem;
	background: var(--color-bg);
	position: relative;
	overflow: hidden;
}

/* Grid background removed */

.products-container {
	max-width: 1100px;
	margin: 0 auto;
	position: relative;
	z-index: 1;
}

.products-header {
	margin-bottom: 2.5rem;
}

.products-title {
	font-family: 'IBM Plex Mono', monospace;
	font-size: 2rem;
	font-weight: 700;
	color: #fff;
	margin-bottom: 0.5rem;
}

.products-subtitle {
	color: var(--color-text-muted);
	font-size: 0.95rem;
}

/* Grid */
.products-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
	gap: 1.25rem;
}

/* Product cards */
.product-card {
	text-decoration: none;
	color: inherit;
}

.product-card .window-titlebar {
	cursor: pointer;
}

/* Featured card */
.product-card.featured {
	border-color: rgba(255, 255, 255, 0.2);
}

.product-card.featured:hover {
	border-color: rgba(255, 255, 255, 0.35);
}

/* Product info */
.product-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 0.75rem;
}

.product-name {
	font-family: 'IBM Plex Mono', monospace;
	font-size: 1.1rem;
	font-weight: 600;
	color: #fff;
}

.product-tag {
	font-family: 'IBM Plex Mono', monospace;
	font-size: 0.7rem;
	font-weight: 600;
	text-transform: uppercase;
	letter-spacing: 0.05em;
	padding: 0.2rem 0.6rem;
	border-radius: 20px;
	border: 1px solid rgba(255, 255, 255, 0.15);
	color: var(--color-text-muted);
}

.featured-tag {
	border-color: rgba(255, 255, 255, 0.3);
	color: #fff;
}

.product-desc {
	color: var(--color-text-muted);
	font-size: 0.9rem;
	line-height: 1.7;
}

/* Responsive */
@media (max-width: 768px) {
	.products-section {
		padding: 3rem 1rem;
	}

	.products-header {
		text-align: center;
	}

	.products-grid {
		grid-template-columns: 1fr;
	}
}
</style>
