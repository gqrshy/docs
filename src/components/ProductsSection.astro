---
// "Our Specialization" — Phoenix-style featured product cards with pricing
import { products, saleConfig, effectivePrice } from '../data/products';

const featured = products.filter(p => p.featured);

function fmt(n: number) {
	return `$${n.toFixed(2)}`;
}
---

<section id="products" class="spec-section">
	<div class="spec-container">
		<div class="spec-header curtain-reveal">
			<h2 class="section-heading spec-heading">
				<span data-i18n="specTitle">Our Specialization</span>
				<a href="#catalog" class="spec-arrow" aria-label="Browse catalog"><i class="ph-bold ph-caret-right"></i></a>
			</h2>
		</div>

		<div class="spec-grid stagger-children">
			{featured.map(p => (
				<article class="spec-card" style={`--card-gradient: ${p.gradient}`}>
					{saleConfig.active && p.salePrice != null && <span class="sale-ribbon">Sale</span>}
					<a href={p.docsUrl || '#catalog'} class="spec-visual" aria-label={p.name}>
						{p.image
							? <img src={p.image} alt={p.name} class="spec-img" loading="lazy" />
							: <span class="spec-logotype">{p.name}</span>}
					</a>
					<div class="spec-body">
						<h3 class="spec-name">{p.name}</h3>
						<p class="spec-desc">{p.description}</p>
						<div class="spec-footer">
							<div class="spec-price">
								{p.price === 0 ? (
									<span class="price-now">Free</span>
								) : (
									<>
										{saleConfig.active && p.salePrice != null && <span class="price-old">{fmt(p.price)}</span>}
										<span class="price-now">{fmt(effectivePrice(p))}</span>
									</>
								)}
							</div>
							{p.price === 0 ? (
								<a href={p.docsUrl} class="spec-cta" aria-label={`View ${p.name} docs`}>
									<i class="ph-bold ph-arrow-right"></i>
								</a>
							) : (
								<button class="spec-cta" data-add-to-cart={p.id} aria-label={`Add ${p.name} to cart`}>
									<i class="ph-bold ph-arrow-right"></i>
								</button>
							)}
						</div>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<script is:inline>
(function() {
	const translations = {
		en: { specTitle: 'Our Specialization' },
		ja: { specTitle: '注目のプロダクト' }
	};

	function apply(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.spec-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) el.textContent = t[key];
		});
	}

	window.addEventListener('langChange', (e) => apply(e.detail.lang));
	apply(window.GashiLang?.get() || 'en');
})();
</script>

<style>
.spec-section {
	padding: 4.5rem 2rem;
	background: var(--bg-raised);
}

.spec-container {
	max-width: 1100px;
	margin: 0 auto;
}

.spec-heading {
	display: flex;
	align-items: center;
	gap: 0.9rem;
	margin-bottom: 2rem;
}

.spec-arrow {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 30px;
	height: 30px;
	border-radius: 50%;
	background: var(--bg-hover);
	color: var(--text-primary);
	font-size: 0.85rem;
	text-decoration: none;
	transition: transform var(--dur-base) var(--ease-bounce), background 0.2s ease;
}

.spec-arrow:hover {
	background: var(--purple-500);
	transform: scale(1.1);
}

.spec-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
	gap: 1.5rem;
}

.spec-card {
	position: relative;
	display: flex;
	flex-direction: column;
	background: var(--card-gradient);
	border: 1px solid var(--border-subtle);
	border-radius: var(--radius-card);
	overflow: hidden;
	box-shadow: var(--shadow-card);
	transition: transform var(--dur-base) var(--ease-bounce),
		border-color var(--dur-base) var(--ease-out-expo),
		box-shadow var(--dur-base) var(--ease-out-expo);
}

.spec-card:hover {
	transform: translateY(-6px);
	border-color: var(--border-strong);
	box-shadow: var(--shadow-card-hover);
}

.sale-ribbon {
	position: absolute;
	top: 0;
	left: 0.9rem;
	z-index: 2;
	writing-mode: vertical-rl;
	background: #ec4899;
	color: #fff;
	font-size: 0.68rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	padding: 0.6rem 0.3rem;
	border-radius: 0 0 6px 6px;
}

.spec-visual {
	display: flex;
	align-items: center;
	justify-content: center;
	height: 250px;
	text-decoration: none;
	overflow: hidden;
}

.spec-img {
	max-height: 82%;
	width: auto;
	transition: transform var(--dur-base) var(--ease-bounce);
}

.spec-card:hover .spec-img { transform: scale(1.08) rotate(-2deg); }

.spec-logotype {
	font-family: var(--font-display);
	font-size: 2.1rem;
	font-weight: 700;
	letter-spacing: -0.02em;
	color: var(--text-primary);
	transition: transform var(--dur-base) var(--ease-bounce);
}

.spec-card:hover .spec-logotype { transform: scale(1.08) rotate(-2deg); }

.spec-body {
	display: flex;
	flex-direction: column;
	flex-grow: 1;
	padding: 1.2rem 1.4rem 1.4rem;
	background: var(--bg-card);
}

.spec-name {
	font-family: var(--font-display);
	font-size: 1.15rem;
	font-weight: 700;
	color: var(--text-primary);
	margin-bottom: 0.4rem;
}

.spec-desc {
	font-size: 0.83rem;
	color: var(--text-secondary);
	line-height: 1.65;
	margin-bottom: 1rem;
	flex-grow: 1;
	display: -webkit-box;
	-webkit-line-clamp: 3;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.spec-footer {
	display: flex;
	align-items: center;
	justify-content: space-between;
}

.spec-price {
	display: flex;
	flex-direction: column;
	line-height: 1.15;
}

.price-old {
	font-size: 0.75rem;
	color: var(--text-muted);
	text-decoration: line-through;
}

.price-now {
	font-family: var(--font-display);
	font-size: 1.5rem;
	font-weight: 700;
	color: var(--text-primary);
}

.spec-cta {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 42px;
	height: 42px;
	border-radius: 50%;
	background: var(--purple-100);
	border: 1px solid var(--purple-200);
	color: var(--purple-600);
	font-size: 1rem;
	cursor: pointer;
	text-decoration: none;
	transition: transform var(--dur-base) var(--ease-bounce), background 0.2s ease, color 0.2s ease;
}

.spec-cta:hover {
	background: var(--purple-600);
	border-color: var(--purple-600);
	color: #fff;
	transform: scale(1.1);
}

.spec-cta:active { transform: scale(0.94); }

@media (max-width: 768px) {
	.spec-section { padding: 3rem 1.25rem; }
}
</style>
