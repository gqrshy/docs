---
// Profile section - B&W window cards, no decorations
import voxelshopLogo from '../assets/voxelshop.png';
---

<section id="profile" class="profile-section">
	<div class="profile-container">
		<h2 class="section-title" data-i18n="linksTitle">Links</h2>

		<!-- Links Section -->
		<div class="links-section">
			<!-- Development -->
			<div class="window-card link-category">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title" data-i18n="linksDev">Development</span>
				</div>
				<div class="window-content link-cards">
					<a href="https://github.com/gqrshy" target="_blank" rel="noopener noreferrer" class="link-card">
						<img src="https://cdn.simpleicons.org/github/white" alt="GitHub" class="link-icon" loading="lazy" />
						<span>GitHub</span>
					</a>
					<a href="https://modrinth.com/user/gashicha" target="_blank" rel="noopener noreferrer" class="link-card">
						<img src="https://cdn.simpleicons.org/modrinth/white" alt="Modrinth" class="link-icon" loading="lazy" />
						<span>Modrinth</span>
					</a>
					<a href="https://www.curseforge.com/members/gqrshy/projects" target="_blank" rel="noopener noreferrer" class="link-card">
						<img src="https://cdn.simpleicons.org/curseforge/white" alt="CurseForge" class="link-icon" loading="lazy" />
						<span>CurseForge</span>
					</a>
					<a href="https://voxel.shop/user/47282/gashi" target="_blank" rel="noopener noreferrer" class="link-card">
						<img src={voxelshopLogo.src} alt="VoxelShop" class="link-icon" />
						<span>VoxelShop</span>
					</a>
				</div>
			</div>

			<!-- Hobbies -->
			<div class="window-card link-category">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title" data-i18n="linksHobby">Hobbies</span>
				</div>
				<div class="window-content link-cards">
					<a href="https://www.youtube.com/@Gqrshy" target="_blank" rel="noopener noreferrer" class="link-card">
						<img src="https://cdn.simpleicons.org/youtube/white" alt="YouTube" class="link-icon" loading="lazy" />
						<span>YouTube</span>
					</a>
					<a href="https://x.com/Gqrshy" target="_blank" rel="noopener noreferrer" class="link-card">
						<img src="https://cdn.simpleicons.org/x/white" alt="X" class="link-icon" loading="lazy" />
						<span>X (Twitter)</span>
					</a>
					<a href="https://note.com/gashicha" target="_blank" rel="noopener noreferrer" class="link-card">
						<img src="https://cdn.simpleicons.org/note/white" alt="note" class="link-icon" loading="lazy" />
						<span>note</span>
					</a>
				</div>
			</div>

			<!-- Gaming -->
			<div class="window-card link-category">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title" data-i18n="linksGaming">Gaming</span>
				</div>
				<div class="window-content link-cards">
					<a href="https://steamcommunity.com/profiles/76561199134198471/" target="_blank" rel="noopener noreferrer" class="link-card">
						<img src="https://cdn.simpleicons.org/steam/white" alt="Steam" class="link-icon" loading="lazy" />
						<span>Steam</span>
					</a>
					<a href="https://tracker.gg/valorant/profile/riot/%E5%B9%B3%E5%92%8C%E4%B8%BB%E7%BE%A9%E8%80%85%23peko/overview?platform=pc&playlist=competitive" target="_blank" rel="noopener noreferrer" class="link-card">
						<img src="https://cdn.simpleicons.org/valorant/white" alt="Valorant" class="link-icon" loading="lazy" />
						<span>Valorant</span>
					</a>
					<a href="https://op.gg/ja/lol/summoners/jp/%E5%B9%B3%E5%92%8C%E4%B8%BB%E7%BE%A9%E8%80%85-peko" target="_blank" rel="noopener noreferrer" class="link-card">
						<img src="https://cdn.simpleicons.org/leagueoflegends/white" alt="League of Legends" class="link-icon" loading="lazy" />
						<span>LoL</span>
					</a>
				</div>
			</div>
		</div>
	</div>
</section>

<script is:inline>
(function() {
	const translations = {
		en: {
			linksTitle: "Links",
			linksDev: "Development",
			linksHobby: "Hobbies",
			linksGaming: "Gaming"
		},
		ja: {
			linksTitle: "リンク",
			linksDev: "開発関連",
			linksHobby: "趣味",
			linksGaming: "ゲーム関連"
		}
	};

	function applyProfileTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.profile-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) {
				el.innerHTML = t[key];
			}
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyProfileTranslations(lang);
	}

	window.addEventListener('langChange', (e) => {
		applyProfileTranslations(e.detail.lang);
	});

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style>
.profile-section {
	padding: 5rem 2rem;
	background: var(--color-bg);
	position: relative;
	overflow: hidden;
}

.profile-container {
	max-width: 900px;
	margin: 0 auto;
	position: relative;
	z-index: 1;
}

.section-title {
	font-size: 1.75rem;
	font-weight: 700;
	margin: 0 0 2rem 0;
	letter-spacing: -0.02em;
	color: var(--color-text);
	font-family: var(--font-mono);
}

/* Links Section */
.links-section {
	display: flex;
	flex-direction: column;
	gap: 1.5rem;
}

.link-category {
	padding: 0;
	background: var(--color-surface);
}

.link-category:hover {
	border-color: var(--border-strong);
}

.link-cards {
	display: flex;
	flex-wrap: wrap;
	gap: 0.75rem;
}

.link-card {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	padding: 0.5rem 0.875rem;
	background: var(--bg-hover);
	border: 1px solid var(--border-subtle);
	border-radius: 8px;
	color: var(--color-text);
	text-decoration: none;
	font-size: 0.8125rem;
	font-weight: 500;
	font-family: var(--font-mono);
	transition: all 0.2s ease;
}

.link-card:hover {
	transform: translateY(-2px);
	border-color: var(--border-strong);
	background: var(--purple-100);
}

.link-icon {
	width: 16px;
	height: 16px;
	object-fit: contain;
}

@media (max-width: 768px) {
	.profile-section {
		padding: 3rem 1rem;
	}

	.section-title {
		text-align: center;
		display: block;
	}

	.link-cards {
		justify-content: center;
	}
}
</style>
