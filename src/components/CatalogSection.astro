---
// "Our catalog" — Phoenix-style: filter sidebar + product grid with Add to cart
import { products, saleConfig, effectivePrice } from '../data/products';

const allTags = ['Cobblemon', 'PvP', 'Library'];
const categories = [
	{ id: 'all', label: 'All' },
	{ id: 'mods', label: 'Mods' },
	{ id: 'plugins', label: 'Plugins' },
	{ id: 'libraries', label: 'Libraries' }
];
const popular = products.filter(p => p.featured);

function fmt(n: number) {
	return `$${n.toFixed(2)}`;
}
---

<section id="catalog" class="catalog-section">
	<div class="catalog-container">
		<div class="catalog-header curtain-reveal">
			<h2 class="section-heading catalog-heading">
				<span data-i18n="catalogTitle">Our catalog</span>
				<span class="catalog-arrow"><i class="ph-bold ph-caret-right"></i></span>
			</h2>
		</div>

		<div class="catalog-layout">
			<!-- Sidebar filters -->
			<aside class="catalog-sidebar">
				<div class="filter-search">
					<input type="text" id="catalog-search" placeholder="Search products..." autocomplete="off" />
					<i class="ph ph-magnifying-glass"></i>
				</div>

				<div class="filter-group">
					<h4 class="filter-title"><span data-i18n="filterCategory">Category</span> <i class="ph-bold ph-minus"></i></h4>
					<div class="filter-chips" id="category-chips">
						{categories.map((c, i) => (
							<button class={`chip ${i === 0 ? 'active' : ''}`} data-category={c.id}>{c.label}</button>
						))}
					</div>
				</div>

				<div class="filter-group">
					<h4 class="filter-title"><span data-i18n="filterTags">Tags</span> <i class="ph-bold ph-minus"></i></h4>
					<div class="filter-chips" id="tag-chips">
						{allTags.map(t => (
							<button class="chip chip-outline" data-tag={t}>{t}</button>
						))}
					</div>
				</div>

				<div class="filter-group">
					<h4 class="filter-title"><span data-i18n="filterSort">Sort by</span> <i class="ph-bold ph-minus"></i></h4>
					<div class="filter-select">
						<select id="catalog-sort">
							<option value="relevance">Relevance</option>
							<option value="price-asc">Price: Low to High</option>
							<option value="price-desc">Price: High to Low</option>
							<option value="name">Name (A–Z)</option>
						</select>
						<i class="ph-bold ph-caret-down"></i>
					</div>
				</div>

				<div class="filter-group">
					<h4 class="filter-title"><span data-i18n="filterPopular">Popular Products</span> <i class="ph-bold ph-minus"></i></h4>
					<div class="popular-list">
						{popular.map(p => (
							<a href={p.docsUrl || '#catalog'} class="popular-item">
								<span class="popular-thumb" style={`background: ${p.gradient}`}>
									{p.image ? <img src={p.image} alt="" loading="lazy" /> : <i class="ph ph-cube"></i>}
								</span>
								<span class="popular-meta">
									<span class="popular-name">{p.name}</span>
									<span class="popular-price">
										{p.price === 0
											? 'Free'
											: <>
												{saleConfig.active && p.salePrice != null && <s>{fmt(p.price)}</s>}
												<em>{fmt(effectivePrice(p))}</em>
												{p.reviews ? ` · ${p.reviews} reviews` : ''}
											</>}
									</span>
								</span>
							</a>
						))}
					</div>
				</div>
			</aside>

			<!-- Product grid -->
			<div class="catalog-grid" id="catalog-grid">
				{products.map(p => (
					<article
						class="cat-card"
						data-id={p.id}
						data-name={p.name.toLowerCase()}
						data-category={p.category}
						data-tags={p.tags.join(',').toLowerCase()}
						data-price={effectivePrice(p)}
					>
						<a href={p.docsUrl || '#'} class="cat-visual" style={`background: ${p.gradient}`} aria-label={p.name}>
							{saleConfig.active && p.salePrice != null && <span class="sale-badge">Sale</span>}
							{p.image
								? <img src={p.image} alt={p.name} class="cat-img" loading="lazy" />
								: <span class="cat-logotype">{p.name}</span>}
						</a>
						<div class="cat-body">
							<h3 class="cat-name">{p.name}</h3>
							<p class="cat-desc">{p.description}</p>
							<div class="cat-footer">
								<div class="cat-price">
									{p.price === 0 ? (
										<span class="price-now">Free</span>
									) : (
										<>
											{saleConfig.active && p.salePrice != null && <span class="price-old">{fmt(p.price)}</span>}
											<span class="price-now">{fmt(effectivePrice(p))}</span>
										</>
									)}
								</div>
								{p.price === 0 ? (
									<a href={p.docsUrl} class="cat-btn cat-btn-ghost">
										<i class="ph ph-book-open"></i> <span data-i18n="catalogDocs">View docs</span>
									</a>
								) : p.externalBuyUrl ? (
									<a href={p.externalBuyUrl} target="_blank" rel="noopener noreferrer" class="cat-btn">
										<i class="ph ph-arrow-up-right"></i> <span data-i18n="catalogBuy">Buy on VoxelShop</span>
									</a>
								) : (
									<button class="cat-btn" data-add-to-cart={p.id}>
										<i class="ph ph-shopping-cart-simple"></i> <span data-i18n="catalogAdd">Add to cart</span>
									</button>
								)}
							</div>
						</div>
					</article>
				))}
				<p class="catalog-empty" id="catalog-empty" hidden data-i18n="catalogEmpty">No products match your filters.</p>
			</div>
		</div>
	</div>
</section>

<script is:inline>
(function () {
	const translations = {
		en: {
			catalogTitle: 'Our catalog',
			filterCategory: 'Category',
			filterTags: 'Tags',
			filterSort: 'Sort by',
			filterPopular: 'Popular Products',
			catalogAdd: 'Add to cart',
			catalogDocs: 'View docs',
			catalogBuy: 'Buy on VoxelShop',
			catalogEmpty: 'No products match your filters.'
		},
		ja: {
			catalogTitle: 'カタログ',
			filterCategory: 'カテゴリ',
			filterTags: 'タグ',
			filterSort: '並び替え',
			filterPopular: '人気のプロダクト',
			catalogAdd: 'カートに追加',
			catalogDocs: 'ドキュメント',
			catalogBuy: 'VoxelShopで購入',
			catalogEmpty: '条件に一致するプロダクトがありません。'
		}
	};

	function apply(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.catalog-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) el.textContent = t[key];
		});
	}

	// Module-level state so delegated handlers keep working even before/after View Transitions swaps.
	let category = 'all';
	const activeTags = new Set();

	function refresh() {
		const grid = document.getElementById('catalog-grid');
		if (!grid) return;
		const cards = [...grid.querySelectorAll('.cat-card')];
		const emptyMsg = document.getElementById('catalog-empty');
		const search = document.getElementById('catalog-search');
		const sortSel = document.getElementById('catalog-sort');
		const q = search?.value.trim().toLowerCase() ?? '';

		let visible = 0;
		cards.forEach(card => {
			const tags = (card.dataset.tags || '').split(',');
			const okCat = category === 'all' || card.dataset.category === category;
			const okTag = activeTags.size === 0 || [...activeTags].some(t => tags.includes(t));
			const okSearch = !q || (card.dataset.name || '').includes(q) || (card.dataset.tags || '').includes(q);
			const show = okCat && okTag && okSearch;
			card.hidden = !show;
			if (show) visible++;
		});
		if (emptyMsg) emptyMsg.hidden = visible > 0;

		// Sort by reordering DOM
		const mode = sortSel?.value || 'relevance';
		if (mode !== 'relevance') {
			const sorted = [...cards].sort((a, b) => {
				if (mode === 'price-asc') return Number(a.dataset.price) - Number(b.dataset.price);
				if (mode === 'price-desc') return Number(b.dataset.price) - Number(a.dataset.price);
				return (a.dataset.name || '').localeCompare(b.dataset.name || '');
			});
			sorted.forEach(c => grid.insertBefore(c, emptyMsg || null));
		} else {
			cards.forEach(c => grid.insertBefore(c, emptyMsg || null));
		}
	}

	// ===== Delegated handlers (work regardless of init timing / View Transitions swaps) =====
	document.addEventListener('click', (e) => {
		const catChip = e.target.closest('#category-chips .chip');
		if (catChip) {
			document.querySelectorAll('#category-chips .chip').forEach(c => c.classList.remove('active'));
			catChip.classList.add('active');
			category = catChip.dataset.category || 'all';
			refresh();
			return;
		}
		const tagChip = e.target.closest('#tag-chips .chip');
		if (tagChip) {
			const tag = (tagChip.dataset.tag || '').toLowerCase();
			if (activeTags.has(tag)) {
				activeTags.delete(tag);
				tagChip.classList.remove('active');
			} else {
				activeTags.add(tag);
				tagChip.classList.add('active');
			}
			refresh();
		}
	});

	document.addEventListener('input', (e) => {
		if (e.target.id === 'catalog-search') refresh();
	});
	document.addEventListener('change', (e) => {
		if (e.target.id === 'catalog-sort') refresh();
	});

	// i18n
	document.addEventListener('langChange', (e) => apply(e.detail.lang));

	// Initial paint + View Transitions re-entry
	function boot() {
		apply(window.GashiLang?.get() || 'en');
		// Reset active styles from server-rendered HTML, then sync to current state
		document.querySelectorAll('#category-chips .chip').forEach(c => {
			c.classList.toggle('active', (c.dataset.category || 'all') === category);
		});
		document.querySelectorAll('#tag-chips .chip').forEach(c => {
			const tag = (c.dataset.tag || '').toLowerCase();
			c.classList.toggle('active', activeTags.has(tag));
		});
		refresh();
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', boot);
	} else {
		boot();
	}
	document.addEventListener('astro:page-load', boot);
})();
</script>

<style>
.catalog-section {
	padding: 4.5rem 2rem 5.5rem;
	background: var(--bg-base);
}

.catalog-container {
	max-width: 1200px;
	margin: 0 auto;
}

.catalog-heading {
	display: flex;
	align-items: center;
	gap: 0.9rem;
	margin-bottom: 2rem;
}

.catalog-arrow {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 30px;
	height: 30px;
	border-radius: 50%;
	background: var(--bg-hover);
	color: var(--text-primary);
	font-size: 0.85rem;
}

.catalog-layout {
	display: grid;
	grid-template-columns: 250px 1fr;
	gap: 2rem;
	align-items: start;
}

/* ===== Sidebar ===== */
.catalog-sidebar {
	background: var(--bg-raised);
	border: 1px solid var(--border-subtle);
	border-radius: var(--radius-card);
	padding: 1.25rem;
	position: sticky;
	top: 90px;
	display: flex;
	flex-direction: column;
	gap: 1.4rem;
}

.filter-search {
	position: relative;
}

.filter-search input {
	width: 100%;
	background: var(--bg-card);
	border: 1px solid var(--border-subtle);
	border-radius: 10px;
	padding: 0.6rem 2.2rem 0.6rem 0.9rem;
	color: var(--text-primary);
	font-family: var(--font-sans);
	font-size: 0.83rem;
	outline: none;
	transition: border-color 0.2s ease;
}

.filter-search input:focus { border-color: var(--purple-400); }
.filter-search input::placeholder { color: var(--text-muted); }

.filter-search i {
	position: absolute;
	right: 0.8rem;
	top: 50%;
	transform: translateY(-50%);
	color: var(--text-muted);
	font-size: 0.95rem;
}

.filter-title {
	display: flex;
	align-items: center;
	justify-content: space-between;
	font-family: var(--font-sans);
	font-size: 0.85rem;
	font-weight: 600;
	color: var(--text-primary);
	margin-bottom: 0.7rem;
}

.filter-title i { color: var(--text-muted); font-size: 0.75rem; }

.filter-chips {
	display: flex;
	flex-wrap: wrap;
	gap: 0.45rem;
}

.chip {
	background: var(--bg-card);
	border: 1px solid var(--border-subtle);
	color: var(--text-secondary);
	font-family: var(--font-sans);
	font-size: 0.75rem;
	font-weight: 500;
	padding: 0.3rem 0.75rem;
	border-radius: 999px;
	cursor: pointer;
	transition: all 0.2s ease;
}

.chip:hover { border-color: var(--purple-400); color: var(--text-primary); }

.chip.active {
	background: var(--purple-500);
	border-color: var(--purple-500);
	color: #fff;
}

.filter-select {
	position: relative;
}

.filter-select select {
	width: 100%;
	appearance: none;
	-webkit-appearance: none;
	-moz-appearance: none;
	background: var(--bg-card);
	border: 1px solid var(--border-subtle);
	border-radius: 10px;
	padding: 0.6rem 2rem 0.6rem 0.9rem;
	color: var(--text-primary);
	font-family: var(--font-sans);
	font-size: 0.83rem;
	font-weight: 500;
	cursor: pointer;
	outline: none;
	transition: border-color 0.2s ease, background 0.2s ease;
}

.filter-select select:hover { border-color: var(--purple-400); }
.filter-select select:focus { border-color: var(--purple-400); }

.filter-select select option {
	background: var(--bg-card);
	color: var(--text-primary);
	font-family: var(--font-sans);
}

.filter-select i {
	position: absolute;
	right: 0.8rem;
	top: 50%;
	transform: translateY(-50%);
	color: var(--text-muted);
	font-size: 0.75rem;
	pointer-events: none;
}

.popular-list {
	display: flex;
	flex-direction: column;
	gap: 0.75rem;
}

.popular-item {
	display: flex;
	align-items: center;
	gap: 0.7rem;
	text-decoration: none;
	border-radius: 10px;
	padding: 0.3rem;
	transition: background 0.2s ease;
}

.popular-item:hover { background: var(--bg-hover); }

.popular-thumb {
	width: 38px;
	height: 38px;
	border-radius: 8px;
	display: flex;
	align-items: center;
	justify-content: center;
	overflow: hidden;
	flex-shrink: 0;
	color: var(--text-secondary);
}

.popular-thumb img { max-width: 80%; max-height: 80%; }

.popular-meta {
	display: flex;
	flex-direction: column;
	line-height: 1.3;
	min-width: 0;
}

.popular-name {
	font-size: 0.8rem;
	font-weight: 600;
	color: var(--text-primary);
}

.popular-price {
	font-size: 0.7rem;
	color: var(--text-muted);
}

.popular-price s { margin-right: 0.3rem; }
.popular-price em { font-style: normal; color: var(--text-accent); font-weight: 600; }

/* ===== Grid ===== */
.catalog-grid {
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
	gap: 1.5rem;
	align-content: start;
}

.catalog-empty {
	grid-column: 1 / -1;
	color: var(--text-muted);
	font-size: 0.9rem;
	padding: 2rem 0;
	text-align: center;
}

.cat-card {
	display: flex;
	flex-direction: column;
}

.cat-visual {
	position: relative;
	display: flex;
	align-items: center;
	justify-content: center;
	aspect-ratio: 1 / 0.92;
	border-radius: var(--radius-card);
	border: 1px solid var(--border-subtle);
	overflow: hidden;
	text-decoration: none;
	transition: transform var(--dur-base) var(--ease-bounce), border-color 0.2s ease;
}

.cat-visual:hover {
	transform: translateY(-4px);
	border-color: var(--border-strong);
}

.sale-badge {
	position: absolute;
	top: 0;
	left: 0.8rem;
	writing-mode: vertical-rl;
	background: #e5484d;
	color: #fff;
	font-size: 0.65rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	padding: 0.55rem 0.28rem;
	border-radius: 0 0 6px 6px;
	z-index: 1;
}

.cat-img {
	max-height: 78%;
	max-width: 82%;
	width: auto;
	transition: transform var(--dur-base) var(--ease-bounce);
}

.cat-visual:hover .cat-img { transform: scale(1.06); }

.cat-logotype {
	font-family: var(--font-display);
	font-size: 1.6rem;
	font-weight: 700;
	color: var(--text-primary);
	letter-spacing: -0.02em;
	text-align: center;
	padding: 0 1rem;
}

.cat-body {
	padding: 0.9rem 0.2rem 0;
	display: flex;
	flex-direction: column;
	flex-grow: 1;
}

.cat-name {
	font-family: var(--font-display);
	font-size: 1.02rem;
	font-weight: 700;
	color: var(--text-primary);
	margin-bottom: 0.35rem;
}

.cat-desc {
	font-size: 0.8rem;
	color: var(--text-secondary);
	line-height: 1.6;
	margin-bottom: 0.9rem;
	flex-grow: 1;
	display: -webkit-box;
	-webkit-line-clamp: 3;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.cat-footer {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 0.75rem;
}

.cat-price {
	display: flex;
	flex-direction: column;
	line-height: 1.15;
}

.price-old {
	font-size: 0.72rem;
	color: var(--text-muted);
	text-decoration: line-through;
}

.price-now {
	font-family: var(--font-display);
	font-size: 1.35rem;
	font-weight: 700;
	color: var(--text-primary);
}

.cat-btn {
	display: inline-flex;
	align-items: center;
	gap: 0.45rem;
	background: var(--purple-500);
	border: none;
	color: #fff;
	font-family: var(--font-sans);
	font-size: 0.8rem;
	font-weight: 600;
	padding: 0.55rem 1.1rem;
	border-radius: 999px;
	cursor: pointer;
	text-decoration: none;
	white-space: nowrap;
	transition: transform var(--dur-base) var(--ease-bounce), filter 0.2s ease, background 0.2s ease;
}

.cat-btn:hover { transform: scale(1.05); filter: brightness(1.15); }
.cat-btn:active { transform: scale(0.95); }

.cat-btn-ghost {
	background: var(--bg-hover);
	color: var(--text-primary);
}

.cat-btn-ghost:hover { background: var(--purple-500); color: #fff; }

@media (max-width: 900px) {
	.catalog-layout { grid-template-columns: 1fr; }
	.catalog-sidebar { position: static; }
	.catalog-section { padding: 3rem 1.25rem 4rem; }
}
</style>
