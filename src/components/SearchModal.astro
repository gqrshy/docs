---
// Docs search modal — Pagefind-powered. The index is generated at build
// time (`pagefind --site` in the build script), so search only works on
// built output; in `astro dev` the modal shows a friendly notice instead.
---

<div class="search-modal" id="search-modal" aria-hidden="true">
	<div class="search-backdrop" id="search-backdrop"></div>
	<div class="search-panel" role="dialog" aria-modal="true" aria-label="Search documentation">
		<div class="search-input-row">
			<i class="ph ph-magnifying-glass search-input-icon"></i>
			<input
				type="text"
				id="search-input"
				class="search-input"
				placeholder="Search documentation…"
				autocomplete="off"
				spellcheck="false"
			/>
			<button class="search-close" id="search-close" aria-label="Close search">esc</button>
		</div>
		<div class="search-results" id="search-results">
			<p class="search-hint">Type to search across all documentation pages.</p>
		</div>
	</div>
</div>

<script is:inline>
(function () {
	function initSearch() {
		const modal = document.getElementById('search-modal');
		const backdrop = document.getElementById('search-backdrop');
		const input = document.getElementById('search-input');
		const closeBtn = document.getElementById('search-close');
		const resultsEl = document.getElementById('search-results');
		if (!modal || !input || !resultsEl || modal.dataset.ready) return;
		modal.dataset.ready = 'true';

		let pagefind = null;
		let pagefindFailed = false;
		let activeIndex = -1;

		async function loadPagefind() {
			if (pagefind || pagefindFailed) return;
			try {
				pagefind = await import('/pagefind/pagefind.js');
				pagefind.init();
			} catch {
				pagefindFailed = true;
			}
		}

		function openModal() {
			modal.classList.add('active');
			modal.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';
			input.focus();
			input.select();
			loadPagefind();
		}

		function closeModal() {
			modal.classList.remove('active');
			modal.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
		}

		function setActive(index) {
			const items = resultsEl.querySelectorAll('.search-result');
			if (!items.length) return;
			activeIndex = Math.max(0, Math.min(index, items.length - 1));
			items.forEach((el, i) => el.classList.toggle('active', i === activeIndex));
			items[activeIndex].scrollIntoView({ block: 'nearest' });
		}

		function cleanUrl(url) {
			return url.replace(/\.html$/, '').replace(/\/index$/, '/');
		}

		async function runSearch(query) {
			if (!query.trim()) {
				activeIndex = -1;
				resultsEl.innerHTML = '<p class="search-hint">Type to search across all documentation pages.</p>';
				return;
			}
			await loadPagefind();
			if (!pagefind) {
				resultsEl.innerHTML = '<p class="search-hint">Search index not available in dev mode. Run a production build to enable search.</p>';
				return;
			}
			const search = await pagefind.debouncedSearch(query);
			if (!search) return; // superseded by a newer keystroke
			if (!search.results.length) {
				activeIndex = -1;
				resultsEl.innerHTML = '<p class="search-hint">No results for &ldquo;' + query.replace(/</g, '&lt;') + '&rdquo;</p>';
				return;
			}
			const top = await Promise.all(search.results.slice(0, 8).map((r) => r.data()));
			resultsEl.innerHTML = top.map((d) => (
				'<a class="search-result" href="' + cleanUrl(d.url) + '">' +
					'<span class="search-result-title">' + d.meta.title + '</span>' +
					'<span class="search-result-excerpt">' + d.excerpt + '</span>' +
				'</a>'
			)).join('');
			activeIndex = -1;
		}

		// pagefind.debouncedSearch handles debouncing; stale calls resolve to null
		input.addEventListener('input', () => runSearch(input.value));

		input.addEventListener('keydown', (e) => {
			if (e.key === 'ArrowDown') { e.preventDefault(); setActive(activeIndex + 1); }
			else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(activeIndex - 1); }
			else if (e.key === 'Enter') {
				const items = resultsEl.querySelectorAll('.search-result');
				const target = items[activeIndex] || items[0];
				if (target) window.location.href = target.getAttribute('href');
			}
		});

		backdrop.addEventListener('click', closeModal);
		closeBtn.addEventListener('click', closeModal);

		document.addEventListener('keydown', (e) => {
			if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
				e.preventDefault();
				modal.classList.contains('active') ? closeModal() : openModal();
			} else if (e.key === 'Escape' && modal.classList.contains('active')) {
				closeModal();
			}
		});

		// Any element with [data-search-trigger] opens the modal
		document.querySelectorAll('[data-search-trigger]').forEach((el) => {
			el.addEventListener('click', openModal);
		});
	}

	initSearch();
	document.addEventListener('astro:page-load', initSearch);
})();
</script>

<style is:global>
.search-modal {
	position: fixed;
	inset: 0;
	z-index: 10000;
	display: flex;
	align-items: flex-start;
	justify-content: center;
	padding: 12vh 1rem 0;
	opacity: 0;
	visibility: hidden;
	transition: opacity 0.2s ease, visibility 0.2s ease;
}

.search-modal.active {
	opacity: 1;
	visibility: visible;
}

.search-backdrop {
	position: absolute;
	inset: 0;
	background: rgba(26, 26, 26, 0.35);
	backdrop-filter: blur(6px);
	-webkit-backdrop-filter: blur(6px);
}

.search-panel {
	position: relative;
	width: 100%;
	max-width: 560px;
	background: var(--bg-card);
	border: 1px solid var(--border-subtle);
	border-radius: var(--radius-card);
	box-shadow: 0 20px 60px rgba(139, 92, 246, 0.18), var(--shadow-card);
	overflow: hidden;
	transform: translateY(8px) scale(0.98);
	transition: transform 0.25s var(--ease-out-expo, ease);
}

.search-modal.active .search-panel {
	transform: translateY(0) scale(1);
}

.search-input-row {
	display: flex;
	align-items: center;
	gap: 0.65rem;
	padding: 0.9rem 1.1rem;
	border-bottom: 1px solid var(--border-subtle);
}

.search-input-icon {
	font-size: 1.15rem;
	color: var(--purple-600);
	flex-shrink: 0;
}

.search-input {
	flex: 1;
	border: none;
	outline: none;
	background: transparent;
	font-family: var(--font-sans);
	font-size: 1rem;
	color: var(--text-primary);
	caret-color: var(--purple-600) !important;
}

.search-input::placeholder {
	color: var(--text-muted);
}

.search-close {
	flex-shrink: 0;
	font-family: var(--font-mono);
	font-size: 0.68rem;
	color: var(--text-muted);
	background: var(--bg-raised);
	border: 1px solid var(--border-subtle);
	border-radius: 6px;
	padding: 0.25rem 0.5rem;
	cursor: pointer;
	transition: color 0.2s ease, border-color 0.2s ease;
}

.search-close:hover {
	color: var(--text-primary);
	border-color: var(--border-strong);
}

.search-results {
	max-height: 55vh;
	overflow-y: auto;
	padding: 0.5rem;
}

.search-hint {
	padding: 1.25rem 1rem;
	text-align: center;
	font-size: 0.88rem;
	color: var(--text-muted);
	margin: 0;
}

.search-result {
	display: flex;
	flex-direction: column;
	gap: 0.2rem;
	padding: 0.7rem 0.9rem;
	border-radius: 10px;
	text-decoration: none;
	transition: background 0.15s ease;
}

.search-result:hover,
.search-result.active {
	background: var(--purple-100);
}

.search-result-title {
	font-size: 0.92rem;
	font-weight: 600;
	color: var(--text-primary);
}

.search-result:hover .search-result-title,
.search-result.active .search-result-title {
	color: var(--purple-600);
}

.search-result-excerpt {
	font-size: 0.8rem;
	line-height: 1.5;
	color: var(--text-secondary);
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.search-result-excerpt mark {
	background: var(--purple-200);
	color: var(--purple-600);
	border-radius: 3px;
	padding: 0 2px;
}

.search-results::-webkit-scrollbar {
	width: 6px;
}

.search-results::-webkit-scrollbar-thumb {
	background: var(--purple-200);
	border-radius: 3px;
}
</style>
