---
// Tech stack section - B&W window cards
---

<section id="techstack" class="techstack-section">
	<div class="techstack-container">
		<h2 class="section-title" data-i18n="techstackTitle">Tech Stack</h2>

		<div class="techstack-grid">
			<div class="techstack-category window-card" data-category="mc">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title" data-i18n="categoryMC">MC Development</span>
				</div>
				<div class="window-content">
					<div class="tech-icons">
						<div class="tech-item"><img src="https://cdn.simpleicons.org/java/white" alt="Java" loading="lazy" /><span>Java</span></div>
						<div class="tech-item"><img src="https://cdn.simpleicons.org/gradle/white" alt="Gradle" loading="lazy" /><span>Gradle</span></div>
						<div class="tech-item"><img src="https://cdn.simpleicons.org/spigotmc/white" alt="Spigot" loading="lazy" /><span>Spigot</span></div>
						<div class="tech-item"><img src="https://cdn.simpleicons.org/papermc/white" alt="Paper" loading="lazy" /><span>Paper</span></div>
					</div>
				</div>
			</div>

			<div class="techstack-category window-card" data-category="cobblemon">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title" data-i18n="categoryCobblemon">Cobblemon</span>
				</div>
				<div class="window-content">
					<div class="tech-icons">
						<div class="tech-item"><img src="https://cdn.simpleicons.org/kotlin/white" alt="Kotlin" loading="lazy" /><span>Kotlin</span></div>
						<div class="tech-item"><span class="tech-text-icon">CB</span><span>Cobblemon API</span></div>
						<div class="tech-item"><span class="tech-text-icon">FD</span><span>Fabric</span></div>
					</div>
				</div>
			</div>

			<div class="techstack-category window-card" data-category="db">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title" data-i18n="categoryDB">Database</span>
				</div>
				<div class="window-content">
					<div class="tech-icons">
						<div class="tech-item"><img src="https://cdn.simpleicons.org/mysql/white" alt="MySQL" loading="lazy" /><span>MySQL</span></div>
						<div class="tech-item"><img src="https://cdn.simpleicons.org/sqlite/white" alt="SQLite" loading="lazy" /><span>SQLite</span></div>
						<div class="tech-item"><img src="https://cdn.simpleicons.org/mongodb/white" alt="MongoDB" loading="lazy" /><span>MongoDB</span></div>
					</div>
				</div>
			</div>

			<div class="techstack-category window-card" data-category="web">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title" data-i18n="categoryWeb">Web</span>
				</div>
				<div class="window-content">
					<div class="tech-icons">
						<div class="tech-item"><img src="https://cdn.simpleicons.org/javascript/white" alt="JavaScript" loading="lazy" /><span>JavaScript</span></div>
						<div class="tech-item"><img src="https://cdn.simpleicons.org/typescript/white" alt="TypeScript" loading="lazy" /><span>TypeScript</span></div>
						<div class="tech-item"><img src="https://cdn.simpleicons.org/astro/white" alt="Astro" loading="lazy" /><span>Astro</span></div>
					</div>
				</div>
			</div>

			<div class="techstack-category window-card" data-category="tools">
				<div class="window-titlebar">
					<span class="window-close"></span>
					<span class="window-title" data-i18n="categoryTools">Tools</span>
				</div>
				<div class="window-content">
					<div class="tech-icons">
						<div class="tech-item"><img src="https://cdn.simpleicons.org/git/white" alt="Git" loading="lazy" /><span>Git</span></div>
						<div class="tech-item"><img src="https://cdn.simpleicons.org/github/white" alt="GitHub" loading="lazy" /><span>GitHub</span></div>
						<div class="tech-item"><img src="https://cdn.simpleicons.org/figma/white" alt="Figma" loading="lazy" /><span>Figma</span></div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script is:inline>
(function() {
	const translations = {
		en: {
			techstackTitle: "Tech Stack",
			categoryMC: "MC Development",
			categoryCobblemon: "Cobblemon",
			categoryDB: "Database",
			categoryWeb: "Web",
			categoryTools: "Tools"
		},
		ja: {
			techstackTitle: "技術スタック",
			categoryMC: "MC開発",
			categoryCobblemon: "Cobblemon",
			categoryDB: "データベース",
			categoryWeb: "Web",
			categoryTools: "ツール"
		}
	};

	function applyTechTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.techstack-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) {
				el.textContent = t[key];
			}
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyTechTranslations(lang);
		setupObserver();
	}

	function setupObserver() {
		const categories = document.querySelectorAll('.techstack-category');
		if (!categories.length) return;

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const items = entry.target.querySelectorAll('.tech-item');
					items.forEach((item, i) => {
						item.style.animationDelay = `${i * 80}ms`;
						item.classList.add('bounce-in');
					});
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.2 });

		categories.forEach(cat => observer.observe(cat));
	}

	window.addEventListener('langChange', (e) => {
		applyTechTranslations(e.detail.lang);
	});

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style>
.techstack-section {
	padding: 5rem 2rem;
	background: var(--color-bg-alt);
	position: relative;
	overflow: hidden;
}

.techstack-section::before {
	content: '';
	position: absolute;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	background-image:
		repeating-linear-gradient(0deg, var(--grid-line) 0, var(--grid-line) 1px, transparent 1px, transparent 48px),
		repeating-linear-gradient(90deg, var(--grid-line) 0, var(--grid-line) 1px, transparent 1px, transparent 48px);
	pointer-events: none;
}

.techstack-container {
	max-width: 1100px;
	margin: 0 auto;
	position: relative;
	z-index: 1;
}

.section-title {
	font-family: 'IBM Plex Mono', monospace;
	font-size: 2rem;
	font-weight: 700;
	color: #fff;
	margin-bottom: 2rem;
}

.techstack-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
	gap: 1.25rem;
}

.techstack-category {
	opacity: 0;
}

.techstack-category.visible {
	opacity: 1;
}

/* Tech items */
.tech-icons {
	display: flex;
	flex-wrap: wrap;
	gap: 0.75rem;
}

.tech-item {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	padding: 0.4rem 0.75rem;
	border: 1px solid rgba(255, 255, 255, 0.08);
	border-radius: 6px;
	font-size: 0.8rem;
	color: var(--color-text-muted);
	font-family: 'IBM Plex Mono', monospace;
	transition: border-color 0.2s ease;
}

.tech-item:hover {
	border-color: rgba(255, 255, 255, 0.2);
}

.tech-item img {
	width: 16px;
	height: 16px;
	object-fit: contain;
}

.tech-text-icon {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 16px;
	height: 16px;
	font-size: 0.55rem;
	font-weight: 700;
	border: 1px solid rgba(255, 255, 255, 0.15);
	border-radius: 3px;
	color: var(--color-text-muted);
}

/* Bounce in animation */
.tech-item {
	opacity: 0;
	transform: scale(0.3);
}

.tech-item.bounce-in {
	animation: bounceIn 0.4s ease forwards;
}

/* Responsive */
@media (max-width: 768px) {
	.techstack-section {
		padding: 3rem 1rem;
	}

	.techstack-grid {
		grid-template-columns: 1fr;
	}
}
</style>
