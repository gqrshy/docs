---
// What We Do — three pillars: mods, plugins, Cobblemon ecosystem
---

<section id="what-we-do" class="whatwedo-section">
	<div class="whatwedo-container">
		<div class="whatwedo-header curtain-reveal">
			<span class="section-label">// What we do</span>
			<h2 class="section-heading" data-i18n="wwdTitle">Three things we craft</h2>
		</div>

		<div class="whatwedo-grid stagger-children">
			<div class="pillar-card">
				<div class="pillar-icon" aria-hidden="true">
					<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 2l8 4.5v9L12 20l-8-4.5v-9L12 2z"/>
						<path d="M12 11L4 6.5M12 11l8-4.5M12 11v9"/>
					</svg>
				</div>
				<h3 class="pillar-name" data-i18n="wwdModsTitle">Mod development</h3>
				<p class="pillar-desc" data-i18n="wwdModsDesc">
					Client and server mods that add new gameplay, systems, and quality-of-life features.
				</p>
				<div class="pillar-badges">
					<span class="badge badge-mod">Fabric</span>
					<span class="badge badge-mod">NeoForge</span>
				</div>
			</div>

			<div class="pillar-card">
				<div class="pillar-icon" aria-hidden="true">
					<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="4" width="18" height="7" rx="2"/>
						<rect x="3" y="13" width="18" height="7" rx="2"/>
						<path d="M7 7.5h.01M7 16.5h.01"/>
					</svg>
				</div>
				<h3 class="pillar-name" data-i18n="wwdPluginsTitle">Plugin development</h3>
				<p class="pillar-desc" data-i18n="wwdPluginsDesc">
					High-performance server plugins built for modern multi-threaded servers.
				</p>
				<div class="pillar-badges">
					<span class="badge badge-plugin">Paper</span>
					<span class="badge badge-plugin">Folia</span>
				</div>
			</div>

			<div class="pillar-card">
				<div class="pillar-icon" aria-hidden="true">
					<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="9"/>
						<path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/>
					</svg>
				</div>
				<h3 class="pillar-name" data-i18n="wwdCobbleTitle">Cobblemon ecosystem</h3>
				<p class="pillar-desc" data-i18n="wwdCobbleDesc">
					Competitive battle systems, libraries, and server tools for the Cobblemon community.
				</p>
				<div class="pillar-badges">
					<span class="badge badge-lib">Cobblemon</span>
					<span class="badge badge-mod">Fabric</span>
				</div>
			</div>
		</div>
	</div>
</section>

<script is:inline>
(function() {
	const translations = {
		en: {
			wwdTitle: "Three things we craft",
			wwdModsTitle: "Mod development",
			wwdModsDesc: "Client and server mods that add new gameplay, systems, and quality-of-life features.",
			wwdPluginsTitle: "Plugin development",
			wwdPluginsDesc: "High-performance server plugins built for modern multi-threaded servers.",
			wwdCobbleTitle: "Cobblemon ecosystem",
			wwdCobbleDesc: "Competitive battle systems, libraries, and server tools for the Cobblemon community."
		},
		ja: {
			wwdTitle: "私たちがつくるもの",
			wwdModsTitle: "Mod開発",
			wwdModsDesc: "新しいゲームプレイやシステム、便利機能を追加するクライアント／サーバーMod。",
			wwdPluginsTitle: "プラグイン開発",
			wwdPluginsDesc: "モダンなマルチスレッドサーバーに対応した高性能プラグイン。",
			wwdCobbleTitle: "Cobblemonエコシステム",
			wwdCobbleDesc: "Cobblemonコミュニティ向けの対戦システム、ライブラリ、サーバーツール。"
		}
	};

	function applyTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.whatwedo-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) {
				el.innerHTML = t[key];
			}
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyTranslations(lang);
	}

	window.addEventListener('langChange', (e) => {
		applyTranslations(e.detail.lang);
	});

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style>
.whatwedo-section {
	padding: 5.5rem 2rem;
	background: var(--bg-raised);
}

.whatwedo-container {
	max-width: 1100px;
	margin: 0 auto;
}

.whatwedo-header {
	display: inline-block;
	margin-bottom: 2.5rem;
}

.whatwedo-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	gap: 1.25rem;
}

.pillar-card {
	background: var(--bg-card);
	border: 1px solid var(--border-subtle);
	border-radius: var(--radius-card);
	padding: 1.75rem;
	transition: transform var(--dur-base) var(--ease-bounce),
		border-color var(--dur-base) var(--ease-out-expo),
		background var(--dur-base) var(--ease-out-expo);
}

.pillar-card:hover {
	transform: translateY(-4px) scale(1.01);
	border-color: var(--border-strong);
	background: var(--bg-hover);
}

.pillar-icon {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 3rem;
	height: 3rem;
	border-radius: 50%;
	background: var(--purple-100);
	color: var(--text-accent);
	margin-bottom: 1.25rem;
	transition: transform var(--dur-base) var(--ease-bounce);
	transition-delay: 0.05s;
}

.pillar-card:hover .pillar-icon {
	transform: translateY(-3px);
}

.pillar-name {
	font-family: var(--font-display);
	font-size: 1.15rem;
	font-weight: 600;
	color: var(--text-primary);
	margin-bottom: 0.6rem;
}

.pillar-desc {
	font-size: 0.9rem;
	color: var(--text-secondary);
	line-height: 1.7;
	margin-bottom: 1.25rem;
}

.pillar-badges {
	display: flex;
	gap: 0.5rem;
	flex-wrap: wrap;
}

@media (max-width: 768px) {
	.whatwedo-section {
		padding: 3.5rem 1.25rem;
	}
}
</style>
