---
// Showcase — Cobblemon integration highlight
---

<section id="showcase" class="showcase-section">
	<div class="showcase-content">
		<div class="showcase-image reveal-up">
			<img src="/gengar.gif" alt="Gengar" />
		</div>
		<div class="showcase-text stagger-children">
			<span class="section-label">// Showcase</span>
			<h2 class="showcase-title" data-i18n="showcaseTitle">Built for Cobblemon</h2>
			<p class="showcase-desc" data-i18n="showcaseDesc">
				Seamlessly integrated with the Cobblemon mod. Bringing competitive Pokemon battles
				to your Minecraft server with style and precision.
			</p>
			<div class="showcase-badges">
				<span class="badge badge-mod">Fabric</span>
				<span class="badge badge-lib">Cobblemon</span>
				<span class="badge badge-plugin">Multiplayer</span>
			</div>
		</div>
	</div>
</section>

<script is:inline>
(function() {
	const translations = {
		en: {
			showcaseTitle: "Built for Cobblemon",
			showcaseDesc: "Seamlessly integrated with the Cobblemon mod. Bringing competitive Pokemon battles to your Minecraft server with style and precision."
		},
		ja: {
			showcaseTitle: "Cobblemonのために",
			showcaseDesc: "Cobblemon Modとシームレスに統合。Minecraftサーバーに競争型ポケモンバトルをスタイリッシュに。"
		}
	};

	function applyShowcaseTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.showcase-section [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (t[key]) {
				el.innerHTML = t[key];
			}
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyShowcaseTranslations(lang);
	}

	window.addEventListener('langChange', (e) => {
		applyShowcaseTranslations(e.detail.lang);
	});

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style is:global>
.showcase-section {
	padding: 5rem 4rem 5rem 0;
	background: var(--bg-base);
	position: relative;
	overflow: hidden;
}

.showcase-content {
	max-width: 1400px;
	margin: 0 auto;
	display: flex;
	gap: 4rem;
	align-items: center;
}

/* Image container — pushed to left edge */
.showcase-image {
	width: 825px;
	flex-shrink: 0;
}

.showcase-image img {
	width: 825px;
	max-width: none;
	height: auto;
	display: block;
}

/* Text — right side, left-aligned */
.showcase-text {
	flex: 1;
	min-width: 320px;
	text-align: left;
	display: flex;
	flex-direction: column;
	gap: 1rem;
}

.showcase-title {
	font-family: var(--font-display);
	font-size: 2rem;
	font-weight: 700;
	color: var(--text-primary);
	letter-spacing: -0.02em;
	text-align: left;
}

.showcase-desc {
	color: var(--text-secondary);
	font-size: 1rem;
	line-height: 1.8;
	text-align: left;
}

.showcase-badges {
	display: flex;
	gap: 0.5rem;
	flex-wrap: wrap;
	margin-top: 0.5rem;
}

/* Responsive */
@media (max-width: 900px) {
	.showcase-content {
		flex-direction: column;
		gap: 2rem;
	}

	.showcase-image {
		flex: none;
		width: 100%;
		max-width: 825px;
		align-self: center;
	}

	.showcase-image img {
		width: 100%;
		max-width: 100%;
	}
}

@media (max-width: 768px) {
	.showcase-section {
		padding: 3rem 1rem;
	}

	.showcase-title {
		font-size: 1.75rem;
	}
}
</style>
