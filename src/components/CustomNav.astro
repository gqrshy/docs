---
// Navigation — Phoenix-style: logo left, center links, Discord + cart right
---

<nav class="custom-nav">
	<div class="nav-container">
		<a href="/" class="nav-brand" aria-label="GashiStudios home">
			<img src="/gashistudios.png" alt="" class="brand-logo" />
			<span class="brand-name">Gashi<br />Studios</span>
		</a>

		<div class="nav-links">
			<a href="/#catalog" class="nav-link" data-i18n="navProducts">Products <i class="ph-bold ph-caret-down nav-caret"></i></a>
			<a href="/docs/cobbleranked/" class="nav-link" data-i18n-html="navDocs">Docs</a>
			<a href="/#team" class="nav-link" data-i18n="navAbout">About Us</a>
			<a href="/#contact" class="nav-link" data-i18n="navHelp">Help</a>
		</div>

		<div class="nav-actions">
			<a href="https://discord.gg/VVVvBTqqyP" target="_blank" rel="noopener noreferrer" class="nav-discord">
				<i class="ph ph-discord-logo"></i>
				<span>Discord</span>
			</a>
			<span class="nav-store-soon" title="In-site store coming soon">
				<i class="ph ph-storefront"></i>
				<span data-i18n="navStoreSoon">Store soon</span>
			</span>
		</div>
	</div>
</nav>

<!-- Mobile menu button -->
<button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Menu">
	<span class="menu-line"></span>
	<span class="menu-line"></span>
	<span class="menu-line"></span>
</button>

<!-- Mobile overlay menu -->
<div class="mobile-menu-overlay" id="mobile-menu-overlay">
	<div class="mobile-menu-content">
		<a href="/#catalog" class="mobile-link" data-i18n="navProductsM">Products</a>
		<a href="/docs/cobbleranked/" class="mobile-link" data-i18n="navDocsM">Docs</a>
		<a href="/#team" class="mobile-link" data-i18n="navAboutM">About Us</a>
		<a href="/#contact" class="mobile-link" data-i18n="navHelpM">Help</a>
		<span class="mobile-link mobile-store-soon">
			<i class="ph ph-storefront"></i> <span data-i18n="navStoreSoonM">Store coming soon</span>
		</span>
		<a href="https://discord.gg/VVVvBTqqyP" target="_blank" rel="noopener noreferrer" class="mobile-discord">
			<i class="ph ph-discord-logo"></i> Discord
		</a>
	</div>
</div>

<script is:inline>
(function() {
	const translations = {
		en: {
			navProducts: 'Products',
			navDocs: 'Docs',
			navAbout: 'About Us',
			navHelp: 'Help',
			navProductsM: 'Products',
			navDocsM: 'Docs',
			navAboutM: 'About Us',
			navHelpM: 'Help',
			navStoreSoon: 'Store soon',
			navStoreSoonM: 'Store coming soon'
		},
		ja: {
			navProducts: 'プロダクト',
			navDocs: 'ドキュメント',
			navAbout: 'チーム',
			navHelp: 'サポート',
			navProductsM: 'プロダクト',
			navDocsM: 'ドキュメント',
			navAboutM: 'チーム',
			navHelpM: 'サポート',
				navStoreSoon: 'ストア準備中',
				navStoreSoonM: 'ストア準備中'
		}
	};

	function applyNavTranslations(lang) {
		const t = translations[lang] || translations.en;
		document.querySelectorAll('.custom-nav [data-i18n], .mobile-menu-overlay [data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (!t[key]) return;
			// Preserve trailing icon (caret) if present
			const icon = el.querySelector('i');
			el.textContent = t[key] + (icon ? ' ' : '');
			if (icon) el.appendChild(icon);
		});
	}

	function init() {
		const lang = window.GashiLang?.get() || 'en';
		applyNavTranslations(lang);

		const menuBtn = document.getElementById('mobile-menu-btn');
		const overlay = document.getElementById('mobile-menu-overlay');

		if (menuBtn && overlay) {
			menuBtn.addEventListener('click', () => {
				menuBtn.classList.toggle('active');
				overlay.classList.toggle('active');
				document.body.style.overflow = overlay.classList.contains('active') ? 'hidden' : '';
			});

			overlay.querySelectorAll('a, button').forEach(link => {
				link.addEventListener('click', () => {
					menuBtn.classList.remove('active');
					overlay.classList.remove('active');
					document.body.style.overflow = '';
				});
			});
		}
	}

	window.addEventListener('langChange', (e) => {
		applyNavTranslations(e.detail.lang);
	});

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
})();
</script>

<style>
.custom-nav {
	position: sticky;
	top: 0;
	left: 0;
	right: 0;
	z-index: 1000;
	padding: 0.9rem 3rem;
	background: rgba(250, 250, 250, 0.85);
	border-bottom: 1px solid var(--border-subtle);
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
}

.nav-container {
	max-width: 1400px;
	margin: 0 auto;
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 2rem;
}

/* Brand */
.nav-brand {
	display: flex;
	align-items: center;
	gap: 0.6rem;
	text-decoration: none;
}

.brand-logo {
	width: 34px;
	height: 34px;
	border-radius: 8px;
}

.brand-name {
	font-family: var(--font-display);
	font-size: 0.82rem;
	font-weight: 700;
	line-height: 1.1;
	color: var(--text-primary);
	letter-spacing: 0.01em;
}

/* Center links */
.nav-links {
	display: flex;
	gap: 0.5rem;
	position: absolute;
	left: 50%;
	transform: translateX(-50%);
}

.nav-link {
	display: inline-flex;
	align-items: center;
	gap: 0.35rem;
	color: var(--text-secondary);
	text-decoration: none;
	font-size: 0.9rem;
	font-weight: 500;
	padding: 0.5rem 1rem;
	border-radius: 10px;
	transition: color 0.2s ease, background 0.2s ease;
}

.nav-caret { font-size: 0.7em; }

.nav-link:hover {
	color: var(--text-primary);
	background: var(--purple-100);
}

/* Right actions */
.nav-actions {
	display: flex;
	align-items: center;
	gap: 0.75rem;
}

.nav-discord {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	color: var(--text-secondary);
	text-decoration: none;
	font-size: 0.88rem;
	font-weight: 500;
	padding: 0.45rem 0.9rem;
	border: 1px solid var(--border-subtle);
	border-radius: 10px;
	transition: all 0.2s ease;
}

.nav-discord i { font-size: 1.15rem; }

.nav-discord:hover {
	color: #fff;
	background: var(--purple-600);
	border-color: var(--purple-600);
}

.nav-icon-btn {
	position: relative;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 38px;
	height: 38px;
	background: transparent;
	border: none;
	border-radius: 10px;
	color: var(--text-secondary);
	font-size: 1.3rem;
	cursor: pointer;
	transition: color 0.2s ease, background 0.2s ease;
}

.nav-icon-btn:hover {
	color: var(--text-primary);
	background: var(--purple-100);
}

.cart-count {
	position: absolute;
	top: 1px;
	right: 1px;
	min-width: 16px;
	height: 16px;
	padding: 0 4px;
	background: var(--purple-600);
	color: #fff;
	font-size: 0.62rem;
	font-weight: 700;
	border-radius: 999px;
	display: flex;
	align-items: center;
	justify-content: center;
	line-height: 1;
}

/* "Store coming soon" badge (in-site cart disabled — buy on VoxelShop) */
	.nav-store-soon {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.4rem 0.75rem;
		border: 1px solid var(--purple-200);
		border-radius: 10px;
		background: var(--purple-100);
		color: var(--purple-600);
		font-family: var(--font-sans);
		font-size: 0.72rem;
		font-weight: 600;
		white-space: nowrap;
		cursor: default;
	}

	.nav-store-soon i {
		font-size: 1.05rem;
	}

	.mobile-store-soon {
		color: var(--text-muted);
		cursor: default;
	}

	/* Mobile menu button */
.mobile-menu-btn {
	display: none;
	position: fixed;
	top: 8px;
	right: 1.25rem;
	z-index: 1002;
	width: 44px;
	height: 44px;
	border: 1px solid var(--color-border);
	background: var(--color-bg-card);
	border-radius: 8px;
	cursor: pointer;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	gap: 5px;
}

.menu-line {
	width: 20px;
	height: 2px;
	background: var(--color-text);
	border-radius: 2px;
	transition: all 0.3s ease;
}

.mobile-menu-btn.active .menu-line:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.mobile-menu-btn.active .menu-line:nth-child(2) { opacity: 0; }
.mobile-menu-btn.active .menu-line:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

/* Mobile overlay */
.mobile-menu-overlay {
	display: none;
	position: fixed;
	inset: 0;
	z-index: 1001;
	background: var(--color-bg);
	opacity: 0;
	pointer-events: none;
	transition: opacity 0.3s ease;
	overflow: hidden;
}

.mobile-menu-overlay.active {
	opacity: 1;
	pointer-events: auto;
}

.mobile-menu-content {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	height: 100%;
	gap: 2rem;
}

.mobile-link {
	display: inline-flex;
	align-items: center;
	gap: 0.6rem;
	color: var(--color-text);
	background: none;
	border: none;
	text-decoration: none;
	font-size: 1.5rem;
	font-weight: 500;
	font-family: var(--font-display);
	cursor: pointer;
	transition: color 0.2s ease;
	opacity: 0;
	transform: translateY(20px);
}

.mobile-menu-overlay.active .mobile-link,
.mobile-menu-overlay.active .mobile-discord {
	animation: fadeInStagger 0.4s ease forwards;
}

.mobile-menu-overlay.active .mobile-link:nth-child(1) { animation-delay: 0.05s; }
.mobile-menu-overlay.active .mobile-link:nth-child(2) { animation-delay: 0.1s; }
.mobile-menu-overlay.active .mobile-link:nth-child(3) { animation-delay: 0.15s; }
.mobile-menu-overlay.active .mobile-link:nth-child(4) { animation-delay: 0.2s; }
.mobile-menu-overlay.active .mobile-link:nth-child(5) { animation-delay: 0.25s; }
.mobile-menu-overlay.active .mobile-discord { animation-delay: 0.3s; }

.mobile-link:hover { color: var(--text-accent); }

.mobile-discord {
	display: inline-flex;
	align-items: center;
	gap: 0.6rem;
	color: #fff;
	background: var(--purple-600);
	text-decoration: none;
	padding: 0.75rem 1.75rem;
	border-radius: 999px;
	font-size: 1rem;
	font-weight: 600;
	margin-top: 1rem;
	opacity: 0;
	transform: translateY(20px);
}

/* Responsive */
@media (max-width: 1000px) {
	.custom-nav { display: none; }
	.mobile-menu-btn { display: flex; }
	.mobile-menu-overlay { display: block; }
}
</style>
