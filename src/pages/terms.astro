---
// Terms and Conditions page - Clean, consolidated layout
import CustomNav from '../components/CustomNav.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/png" href="/gashistudios.png" />
	<meta name="description" content="GashiStudios Terms and Conditions" />
	<title>Terms & Conditions - GashiStudios</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	<script src="https://unpkg.com/@phosphor-icons/web"></script>
</head>
<body>
	<CustomNav />

	<header class="terms-hero">
		<div class="hero-content">
			<div class="hero-badge">
				<i class="ph ph-gavel"></i>
				Legal
			</div>
			<h1>Terms & Conditions</h1>
			<p class="hero-subtitle">Please read these terms carefully before purchasing or using our software.</p>
			<div class="hero-meta">
				<span class="meta-item">
					<i class="ph ph-calendar-blank"></i>
					Last Updated: May 21, 2026
				</span>
				<span class="meta-item">
					<i class="ph ph-clock"></i>
					~6 min read
				</span>
			</div>
		</div>
	</header>

	<div class="terms-layout">
		<aside class="toc">
			<div class="toc-sticky">
				<h3>Contents</h3>
				<ul class="toc-list">
					<li><a href="#commerce" class="toc-link"><i class="ph ph-storefront"></i>Commerce Disclosure</a></li>
					<li><a href="#license" class="toc-link"><i class="ph ph-scroll"></i>License Summary</a></li>
					<li><a href="#source-access" class="toc-link"><i class="ph ph-code"></i>Source Code Access</a></li>
					<li><a href="#usage" class="toc-link"><i class="ph ph-list-checks"></i>Usage Rules</a></li>
					<li><a href="#support" class="toc-link"><i class="ph ph-life-buoy"></i>Support & Refunds</a></li>
					<li><a href="#legal" class="toc-link"><i class="ph ph-scales"></i>Legal</a></li>
					<li><a href="#contact" class="toc-link"><i class="ph ph-envelope"></i>Contact</a></li>
				</ul>
			</div>
		</aside>

		<main class="terms-content">
			<!-- Commerce Disclosure -->
			<section id="commerce" class="terms-section">
				<div class="section-header">
					<i class="ph ph-storefront section-icon"></i>
					<h2>Commerce Disclosure (Japan)</h2>
				</div>
				<p class="section-intro">This software is sold through VoxelShop and complies with Japan's Specified Commercial Transaction Act (特定商取引法).</p>

				<div class="info-card">
					<h3>Business Information</h3>
					<div class="info-grid">
						<div class="info-item">
							<span class="info-label">Representative</span>
							<span class="info-value highlight">Shiga Minato</span>
						</div>
						<div class="info-item">
							<span class="info-label">Email</span>
							<span class="info-value highlight">gashistudios.llc@gmail.com</span>
						</div>
					</div>
				</div>

				<div class="info-row">
					<div class="info-card small">
						<i class="ph ph-currency-dollar"></i>
						<h4>Pricing</h4>
						<p class="price">$10 USD</p>
						<p class="note">Subject to change with future updates</p>
					</div>
					<div class="info-card small">
						<i class="ph ph-credit-card"></i>
						<h4>Payment</h4>
						<p>Credit Card (Stripe)</p>
					</div>
					<div class="info-card small">
						<i class="ph ph-download-simple"></i>
						<h4>Delivery</h4>
						<p>Instant via VoxelShop</p>
					</div>
				</div>
			</section>

			<!-- License Summary -->
			<section id="license" class="terms-section">
				<div class="section-header">
					<i class="ph ph-scroll section-icon"></i>
					<h2>License Summary</h2>
				</div>
				<p class="section-intro">CobbleRanked is premium software. By purchasing, downloading, or using it, you agree to these terms.</p>

				<div class="license-card">
					<div class="license-type">
						<i class="ph ph-key"></i>
						<strong>Type:</strong> Limited, Non-Exclusive, Non-Transferable, Revocable License
					</div>
					<div class="license-scope">
						<i class="ph ph-globe"></i>
						<strong>Scope:</strong> Personal and commercial server use permitted
					</div>
					<div class="license-bound">
						<i class="ph ph-user"></i>
						<strong>Bound to:</strong> Original purchaser only (non-transferable)
					</div>
				</div>
			</section>

			<!-- Source Code Access -->
			<section id="source-access" class="terms-section">
				<div class="section-header">
					<i class="ph ph-code section-icon"></i>
					<h2>Source Code Access</h2>
				</div>
				<p class="section-intro">Customers who have purchased CobbleRanked may request access to our private GitHub repository as contributors.</p>

				<div class="info-row">
					<div class="info-card half">
						<h4><i class="ph ph-check-circle"></i> How to Request</h4>
						<p class="note">You must have purchased CobbleRanked to request access. Please open a ticket and provide:</p>
						<ul class="compact-list">
							<li><strong>Proof of purchase</strong> (VoxelShop receipt or transaction ID)</li>
							<li><strong>GitHub username</strong> (e.g. <code>username</code> or <code>@username</code>)</li>
							<li><strong>Contact information</strong> (Discord server invite you own, or email address)</li>
						</ul>
					</div>
					<div class="info-card half">
						<h4><i class="ph ph-github-logo"></i> Access Terms</h4>
						<ul class="compact-list">
							<li>Access granted as GitHub contributor</li>
							<li>Non-refundable once access is provided</li>
							<li>Access is non-transferable</li>
							<li>Repository remains private</li>
						</ul>
					</div>
				</div>

				<div class="license-note">
					<div>
						<i class="ph ph-info"></i>
						<strong>Permitted Uses:</strong>
					</div>
					<ul>
						<li>Read and study source code for learning purposes</li>
						<li>Submit pull requests to official repository</li>
						<li>Fork for non-Fabric environments (e.g., Arclight) - private only</li>
					</ul>
				</div>

				<div class="warning-box">
					<div>
						<i class="ph ph-warning"></i>
						<strong>Prohibited:</strong>
					</div>
					<ul>
						<li>Redistribution or re-distribution of the source code in any form</li>
						<li>Creating independent derivative works</li>
						<li>Sharing access with others</li>
						<li>Making forks public (except for PRs)</li>
					</ul>
				</div>
			</section>

			<!-- Usage Rules -->
			<section id="usage" class="terms-section">
				<div class="section-header">
					<i class="ph ph-list-checks section-icon"></i>
					<h2>Usage Rules</h2>
				</div>
				<p class="section-intro">Clear guidelines on what you can and cannot do with CobbleRanked.</p>

				<div class="rules-grid">
					<div class="rule-card allowed">
						<div class="rule-header">
							<i class="ph ph-check-circle"></i>
							<h3>Permitted</h3>
						</div>
						<ul class="rule-list">
							<li>Use on personal Minecraft client</li>
							<li>Install on servers you own/operate</li>
							<li>Use on monetized/commercial servers</li>
							<li>Install on multiple servers you own</li>
							<li>Read and study source code (if granted access)</li>
							<li>Submit pull requests to official repo</li>
							<li>Fork for non-Fabric environments (Arclight, etc.) - private only</li>
						</ul>
					</div>

					<div class="rule-card prohibited">
						<div class="rule-header">
							<i class="ph ph-x-circle"></i>
							<h3>Prohibited</h3>
						</div>
						<ul class="rule-list">
							<li>Redistributing, sublicensing, or transferring the software</li>
							<li>Selling, renting, or leasing the software</li>
							<li>Sharing your purchased copy with others</li>
							<li>Uploading to file-sharing sites or mod repositories</li>
							<li>Including in modpacks without explicit written consent</li>
							<li>Publicly claiming to be the original author/developer</li>
							<li>Impersonating Gashi Studios or representatives</li>
							<li>Redistributing modified versions or derivatives</li>
							<li>Removing or altering proprietary notices/licenses</li>
							<li>Using source code in other projects without permission</li>
						</ul>
					</div>
				</div>

				<div class="danger-box">
					<i class="ph ph-warning-octagon"></i>
					<strong>Violations will result in immediate license termination and may lead to legal action.</strong>
				</div>
			</section>

			<!-- Support & Refunds -->
			<section id="support" class="terms-section">
				<div class="section-header">
					<i class="ph ph-life-buoy section-icon"></i>
					<h2>Support & Refunds</h2>
				</div>

				<div class="info-row">
					<div class="info-card half">
						<h4><i class="ph ph-arrows-clockwise"></i> Updates</h4>
						<ul class="compact-list">
							<li>Free updates at our discretion</li>
							<li>May include bug fixes, features, compatibility</li>
							<li>No guarantee of continued updates</li>
						</ul>
					</div>
					<div class="info-card half">
						<h4><i class="ph ph-chat-circle-text"></i> Support</h4>
						<ul class="compact-list">
							<li>Community support via Discord</li>
							<li>Bug reports via Discord or email</li>
							<li>Third-party mod conflicts not supported</li>
						</ul>
					</div>
				</div>

				<div class="refund-section">
					<h3><i class="ph ph-arrow-u-up-left"></i> Refund Policy (Updated May 2026)</h3>

					<div class="refund-card standard">
						<h4>Standard Policy</h4>
						<p>Due to the digital nature of this product, returns and refunds are not available after download.</p>
					</div>

					<div class="refund-card special">
						<h4>Source Code Access & Refunds</h4>
						<p>Users who have been granted source code access are no longer eligible for refunds.</p>
						<p class="note"><i class="ph ph-warning"></i> Once source code access is provided, refunds are no longer available.</p>
					</div>
				</div>
			</section>

			<!-- Legal -->
			<section id="legal" class="terms-section">
				<div class="section-header">
					<i class="ph ph-scales section-icon"></i>
					<h2>Legal</h2>
				</div>

				<div class="legal-grid">
					<div class="legal-card">
						<h3><i class="ph ph-shield-warning"></i> Disclaimer</h3>
						<p>Software provided "AS IS" without warranties. No guarantees for error-free operation or compatibility.</p>
					</div>

					<div class="legal-card">
						<h3><i class="ph ph-warning-circle"></i> Liability Limitation</h3>
						<p>Maximum liability limited to purchase price. Not liable for damages, data loss, or business interruption.</p>
					</div>

					<div class="legal-card">
						<h3><i class="ph ph-copyright"></i> Ownership</h3>
						<p>All rights remain with Gashi Studios. License grants usage rights only, not ownership.</p>
					</div>

					<div class="legal-card">
						<h3><i class="ph ph-user-gear"></i> Termination</h3>
						<p>License terminates automatically upon violation. Must cease use and delete all copies.</p>
					</div>

					<div class="legal-card">
						<h3><i class="ph ph-lock-key"></i> Data & Privacy</h3>
						<p>Anonymous usage data may be collected for diagnostics. No PII collected without consent.</p>
					</div>

					<div class="legal-card">
						<h3><i class="ph ph-gavel"></i> Governing Law</h3>
						<p>Governed by laws of Japan. Dispute resolution: Tokyo, Japan.</p>
					</div>
				</div>
			</section>

			<!-- Contact -->
			<section id="contact" class="terms-section">
				<div class="section-header">
					<i class="ph ph-envelope section-icon"></i>
					<h2>Contact Information</h2>
				</div>
				<p class="section-intro">For questions, support, or licensing inquiries:</p>

				<div class="contact-grid">
					<a href="mailto:gashistudios.llc@gmail.com" class="contact-card">
						<i class="ph ph-envelope-simple"></i>
						<div>
							<span class="contact-label">Email</span>
							<span class="contact-value">gashistudios.llc@gmail.com</span>
						</div>
					</a>
					<a href="https://discord.gg/VVVvBTqqyP" target="_blank" class="contact-card">
						<i class="ph ph-discord-logo"></i>
						<div>
							<span class="contact-label">Discord</span>
							<span class="contact-value">Join Server</span>
						</div>
					</a>
					<a href="https://voxel.shop/product/8733/cobbleranked" target="_blank" class="contact-card">
						<i class="ph ph-shopping-cart"></i>
						<div>
							<span class="contact-label">Purchase</span>
							<span class="contact-value">VoxelShop</span>
						</div>
					</a>
				</div>
			</section>

			<!-- Final Notes -->
			<section class="terms-section final">
				<div class="final-notes">
					<div class="final-item">
						<h4><i class="ph ph-pencil-simple"></i> Changes to Terms</h4>
						<p>Gashi Studios reserves the right to update these terms at any time. Continued use constitutes acceptance.</p>
					</div>
					<div class="final-item">
						<h4><i class="ph ph-scissors"></i> Severability</h4>
						<p>If any provision is invalid, remaining provisions stay in effect.</p>
					</div>
					<div class="final-item">
						<h4><i class="ph ph-file-text"></i> Entire Agreement</h4>
						<p>These terms constitute the entire agreement between you and Gashi Studios.</p>
					</div>
				</div>

				<div class="acceptance-box">
					<strong><i class="ph ph-check-circle"></i> Acceptance</strong>
					<p>By purchasing and using the Software, you acknowledge that you have read, understood, and agree to be bound by these Terms and Conditions.</p>
				</div>

				<div class="copyright">
					© 2026 Gashi Studios. All rights reserved.
				</div>
			</section>
		</main>
	</div>

	<div class="footer-transition"></div>
	<Footer />

	<button id="backToTop" class="back-to-top" aria-label="Back to top">
		<i class="ph ph-arrow-up"></i>
	</button>

	<script is:inline>
		document.querySelectorAll('.toc-link').forEach(link => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const target = document.querySelector(link.getAttribute('href'));
				if (target) {
					target.scrollIntoView({ behavior: 'smooth', block: 'start' });
				}
			});
		});

		const sections = document.querySelectorAll('.terms-section[id]');
		const tocLinks = document.querySelectorAll('.toc-link');

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					tocLinks.forEach(link => {
						link.classList.remove('active');
						if (link.getAttribute('href') === '#' + entry.target.id) {
							link.classList.add('active');
						}
					});
				}
			});
		}, { rootMargin: '-20% 0px -70% 0px' });

		sections.forEach(section => observer.observe(section));

		const backToTop = document.getElementById('backToTop');
		window.addEventListener('scroll', () => {
			if (window.scrollY > 500) {
				backToTop.classList.add('visible');
			} else {
				backToTop.classList.remove('visible');
			}
		});

		backToTop.addEventListener('click', () => {
			window.scrollTo({ top: 0, behavior: 'smooth' });
		});
	</script>

	<style>
		:root {
			--color-bg: #0a0a0f;
			--color-bg-alt: #111118;
			--color-bg-card: #16161e;
			--color-text: #e4e4e7;
			--color-text-muted: #a1a1aa;
			--color-primary: #ffffff;
			--color-primary-light: rgba(255,255,255,0.7);
			--color-border: rgba(255, 255, 255, 0.1);
			--color-success: #22c55e;
			--color-danger: #ef4444;
			--color-warning: #f59e0b;
		}

		* { margin: 0; padding: 0; box-sizing: border-box; }

		html {
			scroll-behavior: smooth;
			scroll-padding-top: 100px;
		}

		body {
			font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
			background: var(--color-bg);
			color: var(--color-text);
			line-height: 1.6;
		}

		a { color: var(--color-primary); text-decoration: none; transition: 0.2s; }
		a:hover { color: var(--color-primary-light); }

		/* Hero */
		.terms-hero {
			padding: 6rem 2rem 3rem;
			background: var(--color-bg-alt);
			border-bottom: 1px solid var(--color-border);
			text-align: center;
		}

		.hero-badge {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			background: rgba(255, 255, 255, 0.1);
			color: var(--color-primary-light);
			padding: 0.4rem 1rem;
			border-radius: 20px;
			font-size: 0.85rem;
			font-weight: 500;
			margin-bottom: 1rem;
		}

		.terms-hero h1 {
			font-size: 2.5rem;
			font-weight: 700;
			margin-bottom: 1rem;
		}

		.hero-subtitle {
			color: var(--color-text-muted);
			font-size: 1.1rem;
			margin-bottom: 1.5rem;
		}

		.hero-meta {
			display: flex;
			gap: 2rem;
			justify-content: center;
			flex-wrap: wrap;
		}

		.meta-item {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			color: var(--color-text-muted);
			font-size: 0.9rem;
		}

		/* Layout */
		.terms-layout {
			max-width: 1200px;
			margin: 0 auto;
			display: grid;
			grid-template-columns: 250px 1fr;
			gap: 3rem;
			padding: 3rem 2rem;
		}

		/* TOC */
		.toc-sticky {
			position: sticky;
			top: 100px;
		}

		.toc h3 {
			color: var(--color-text-muted);
			font-size: 0.75rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 1px;
			margin-bottom: 1rem;
		}

		.toc-list { list-style: none; }

		.toc-link {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			padding: 0.6rem 0;
			padding-left: 0.75rem;
			color: var(--color-text-muted);
			font-size: 0.9rem;
			border-left: 2px solid rgba(255, 255, 255, 0.2);
			transition: all 0.2s;
		}

		.toc-link:hover {
			color: var(--color-primary);
			border-left-color: rgba(255, 255, 255, 0.4);
		}

		.toc-link.active {
			color: var(--color-primary);
			border-left-color: var(--color-primary);
			background: rgba(255, 255, 255, 0.05);
		}

		.toc-link i { font-size: 1.1rem; }

		/* Content */
		.terms-content { max-width: 850px; }

		.terms-section {
			margin-bottom: 4rem;
			padding-bottom: 2rem;
			border-bottom: 1px solid var(--color-border);
		}

		.terms-section.final { border-bottom: none; }

		.section-header {
			display: flex;
			align-items: center;
			gap: 1rem;
			margin-bottom: 1rem;
		}

		.section-header h2 {
			font-size: 1.5rem;
			font-weight: 600;
		}

		.section-icon, .section-header i {
			width: 40px;
			height: 40px;
			display: flex;
			align-items: center;
			justify-content: center;
			background: rgba(255, 255, 255, 0.1);
			border-radius: 10px;
			font-size: 1.25rem;
		}

		.section-intro {
			color: var(--color-text-muted);
			margin-bottom: 1.5rem;
		}

		/* Cards */
		.info-card {
			background: var(--color-bg-card);
			border: 1px solid var(--color-border);
			border-radius: 12px;
			padding: 1.5rem;
			margin-bottom: 1rem;
		}

		.info-card h3, .info-card h4 {
			color: var(--color-text);
			margin-bottom: 0.75rem;
			display: flex;
			align-items: center;
			gap: 0.5rem;
		}

		.info-card h4 i {
			color: var(--color-primary-light);
			font-size: 1.25rem;
		}

		.info-grid {
			display: grid;
			gap: 1rem;
		}

		.info-item {
			display: flex;
			justify-content: space-between;
			padding: 0.5rem 0;
			border-bottom: 1px solid var(--color-border);
		}

		.info-item:last-child { border-bottom: none; }

		.info-label { color: var(--color-text-muted); }
		.info-value { color: var(--color-text); }
		.info-value.highlight { color: var(--color-primary-light); }

		.info-row {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
			gap: 1.5rem;
			margin-bottom: 1.5rem;
		}

		.info-card.small {
			text-align: center;
			padding: 1.75rem 1.25rem;
		}

		.info-card.small i {
			font-size: 2rem;
			color: var(--color-primary);
			margin-bottom: 0.5rem;
		}

		.info-card.half { margin-bottom: 0; }

		.price { font-size: 1.75rem; font-weight: 700; }
		.note { font-size: 0.85rem; color: var(--color-text-muted); margin-top: 0.5rem; }

		/* License Card */
		.license-card {
			background: var(--color-bg-card);
			border: 1px solid var(--color-border);
			border-radius: 12px;
			padding: 1.75rem;
		}

		.license-card > div {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			padding: 0.75rem 0;
			border-bottom: 1px solid var(--color-border);
		}

		.license-card > div:last-child { border-bottom: none; }

		.license-card i {
			color: var(--color-primary-light);
			font-size: 1.25rem;
			flex-shrink: 0;
		}

		/* License Note */
		.license-note {
			background: rgba(34, 197, 94, 0.1);
			border: 1px solid rgba(34, 197, 94, 0.3);
			border-radius: 10px;
			padding: 1.25rem;
			margin-bottom: 1rem;
		}

		.license-note > div {
			display: flex;
			align-items: flex-start;
			gap: 0.75rem;
			margin-bottom: 0.75rem;
		}

		.license-note i {
			color: var(--color-success);
			font-size: 1.25rem;
			flex-shrink: 0;
			margin-top: 0.15rem;
		}

		.license-note strong {
			color: var(--color-success);
			display: block;
			margin-bottom: 0.5rem;
		}

		.license-note ul {
			list-style: none;
			margin-top: 0.75rem;
		}

		.license-note li {
			padding-left: 1.25rem;
			position: relative;
			color: var(--color-text-muted);
			font-size: 0.9rem;
			margin-bottom: 0.4rem;
		}

		.license-note li::before {
			content: '✓';
			position: absolute;
			left: 0;
			color: var(--color-success);
			font-weight: bold;
		}

		/* Warning Box */
		.warning-box {
			background: rgba(245, 158, 11, 0.1);
			border: 1px solid rgba(245, 158, 11, 0.3);
			border-radius: 10px;
			padding: 1.25rem;
			margin-bottom: 1rem;
		}

		.warning-box > div {
			display: flex;
			align-items: flex-start;
			gap: 0.75rem;
			margin-bottom: 0.75rem;
		}

		.warning-box i {
			color: var(--color-warning);
			font-size: 1.25rem;
			flex-shrink: 0;
			margin-top: 0.15rem;
		}

		.warning-box strong {
			color: var(--color-warning);
			display: block;
			margin-bottom: 0.5rem;
		}

		.warning-box ul {
			list-style: none;
			margin-top: 0.75rem;
		}

		.warning-box li {
			padding-left: 1.25rem;
			position: relative;
			color: var(--color-text-muted);
			font-size: 0.9rem;
			margin-bottom: 0.4rem;
		}

		.warning-box li::before {
			content: '✗';
			position: absolute;
			left: 0;
			color: var(--color-warning);
			font-weight: bold;
		}

		/* Compact List */
		.compact-list {
			list-style: none;
		}

		.compact-list li {
			padding-left: 1rem;
			position: relative;
			margin-bottom: 0.5rem;
			color: var(--color-text-muted);
			font-size: 0.9rem;
		}

		.compact-list li::before {
			content: '–';
			position: absolute;
			left: 0;
		}

		.compact-list h4 { display: flex; align-items: center; gap: 0.5rem !important; }

		/* Rules Grid */
		.rules-grid {
			display: grid;
			gap: 2rem;
			margin-bottom: 1.5rem;
		}

		.rule-card {
			background: var(--color-bg-card);
			border: 1px solid var(--color-border);
			border-radius: 12px;
			padding: 1.75rem;
		}

		.rule-card.allowed {
			border-color: rgba(34, 197, 94, 0.3);
		}

		.rule-card.prohibited {
			border-color: rgba(239, 68, 68, 0.3);
		}

		.rule-header {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			margin-bottom: 1rem;
		}

		.rule-card.allowed .rule-header i {
			color: var(--color-success);
			font-size: 1.5rem;
		}

		.rule-card.prohibited .rule-header i {
			color: var(--color-danger);
			font-size: 1.5rem;
		}

		.rule-card h3 { font-size: 1.1rem; }

		.rule-list {
			list-style: none;
		}

		.rule-list li {
			padding-left: 1.5rem;
			position: relative;
			margin-bottom: 0.6rem;
			color: var(--color-text-muted);
			font-size: 0.9rem;
		}

		.rule-card.allowed .rule-list li::before {
			content: '✓';
			position: absolute;
			left: 0;
			color: var(--color-success);
			font-weight: bold;
		}

		.rule-card.prohibited .rule-list li::before {
			content: '✗';
			position: absolute;
			left: 0;
			color: var(--color-danger);
			font-weight: bold;
		}

		/* Danger Box */
		.danger-box {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			background: rgba(239, 68, 68, 0.1);
			border: 1px solid rgba(239, 68, 68, 0.3);
			border-radius: 10px;
			padding: 1rem;
			text-align: center;
			justify-content: center;
		}

		.danger-box i {
			color: var(--color-danger);
			font-size: 1.5rem;
		}

		/* Refund Section */
		.refund-section {
			margin-top: 1.5rem;
		}

		.refund-section h3 {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			margin-bottom: 1rem;
			color: var(--color-text);
		}

		.refund-card {
			background: var(--color-bg-card);
			border: 1px solid var(--color-border);
			border-radius: 10px;
			padding: 1.25rem;
			margin-bottom: 1rem;
		}

		.refund-card.standard {
			border-left: 3px solid var(--color-text-muted);
		}

		.refund-card.special {
			border-left: 3px solid var(--color-warning);
		}

		.refund-card h4 {
			margin-bottom: 0.5rem;
			color: var(--color-text);
		}

		.refund-card .note {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			margin-top: 0.75rem;
			color: var(--color-warning);
		}

		/* Legal Grid */
		.legal-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			gap: 1.5rem;
		}

		.legal-card {
			background: var(--color-bg-card);
			border: 1px solid var(--color-border);
			border-radius: 10px;
			padding: 1.5rem;
		}

		.legal-card h3 {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			font-size: 1rem;
			margin-bottom: 0.5rem;
			color: var(--color-text);
		}

		.legal-card h3 i {
			color: var(--color-primary-light);
		}

		.legal-card p {
			color: var(--color-text-muted);
			font-size: 0.9rem;
		}

		/* Contact Grid */
		.contact-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 1.5rem;
			margin-top: 1.5rem;
		}

		.contact-card {
			display: flex;
			align-items: center;
			gap: 1rem;
			background: var(--color-bg-card);
			border: 1px solid var(--color-border);
			border-radius: 10px;
			padding: 1.5rem;
			transition: all 0.2s;
		}

		.contact-card:hover {
			border-color: var(--color-primary);
			transform: translateY(-2px);
		}

		.contact-card i {
			font-size: 1.5rem;
			color: var(--color-primary);
		}

		.contact-card > div {
			display: flex;
			flex-direction: column;
		}

		.contact-label {
			font-size: 0.8rem;
			color: var(--color-text-muted);
		}

		.contact-value {
			color: var(--color-text);
			font-weight: 500;
		}

		/* Final Notes */
		.final-notes {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			gap: 1.25rem;
			margin-bottom: 1.5rem;
		}

		.final-item {
			background: var(--color-bg-card);
			border: 1px solid var(--color-border);
			border-radius: 10px;
			padding: 1.25rem;
		}

		.final-item h4 {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			margin-bottom: 0.5rem;
			color: var(--color-text);
		}

		.final-item h4 i { color: var(--color-primary); }
		.final-item p { color: var(--color-text-muted); font-size: 0.9rem; }

		/* Acceptance Box */
		.acceptance-box {
			display: flex;
			align-items: flex-start;
			gap: 0.75rem;
			background: rgba(255, 255, 255, 0.05);
			border: 1px solid var(--color-border);
			border-radius: 10px;
			padding: 1.5rem;
			text-align: center;
			justify-content: center;
			margin-bottom: 1.5rem;
		}

		.acceptance-box strong {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			color: var(--color-primary-light);
		}

		.acceptance-box i {
			color: var(--color-success);
			font-size: 1.25rem;
		}

		.acceptance-box p {
			color: var(--color-text-muted);
			margin-top: 0.5rem;
		}

		.copyright {
			text-align: center;
			color: var(--color-text-muted);
			font-size: 0.9rem;
			padding-top: 1.5rem;
			border-top: 1px solid var(--color-border);
		}

		/* Back to Top */
		.back-to-top {
			position: fixed;
			bottom: 2rem;
			right: 2rem;
			width: 44px;
			height: 44px;
			background: var(--color-primary);
			border: none;
			border-radius: 50%;
			color: #000;
			cursor: pointer;
			opacity: 0;
			visibility: hidden;
			transition: all 0.3s;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.25rem;
		}

		.back-to-top.visible {
			opacity: 1;
			visibility: visible;
		}

		.back-to-top:hover {
			transform: translateY(-3px);
		}

		.footer-transition {
			height: 60px;
			background: var(--color-bg);
		}

		/* Responsive */
		@media (max-width: 992px) {
			.terms-layout {
				grid-template-columns: 1fr;
			}

			.toc { display: none; }
			.contact-grid { grid-template-columns: 1fr; }
		}

		@media (max-width: 768px) {
			.terms-hero h1 { font-size: 2rem; }
			.info-row { grid-template-columns: 1fr; }
			.rules-grid { grid-template-columns: 1fr; }
			.legal-grid { grid-template-columns: 1fr; }
		}

		@media (max-width: 576px) {
			.terms-hero { padding: 4rem 1rem 2rem; }
			.terms-hero h1 { font-size: 1.75rem; }
			.terms-layout { padding: 2rem 1rem; }
			.final-notes { grid-template-columns: 1fr; }
		}
	</style>
</body>
</html>
