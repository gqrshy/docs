---
import '../styles/tokens.css';
import '@phosphor-icons/web/regular';
import '@phosphor-icons/web/bold';
import CustomNav from '../components/CustomNav.astro';
import Footer from '../components/Footer.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/png" href="/gashistudios.png" />
	<meta name="description" content="GashiStudios Server - ゲーマーが好きそうな要素を全部突っ込んだMinecraftサーバー" />
	<title>GashiStudios Server</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800;900" rel="stylesheet">
</head>
<body>
	<CustomNav />

	<!-- Hero Section -->
	<section class="hero">
		<div class="hero-bg"></div>
		<div class="hero-particles"></div>
		<div class="hero-content">
			<p class="hero-subtitle" data-i18n="heroSubtitle">COMING MARCH 2026</p>
			<h1 class="hero-title">
				<span class="hero-title-line" data-i18n="heroTitle1">ゲーマーが好きな要素</span>
				<span class="hero-title-line hero-title-accent" data-i18n="heroTitle2">全部入り。</span>
			</h1>
			<p class="hero-desc" data-i18n="heroDesc">競技性、MMO、PvP/PvE、育成、経済、スピード感と中毒性。<br>1年以上かけて本気で作り込んだMinecraftサーバー。</p>
			<div class="hero-cta">
				<a href="https://discord.gg/VVVvBTqqyP" class="btn-primary" target="_blank">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
						<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
					</svg>
					<span data-i18n="ctaDiscord">Discordで最新情報をチェック</span>
				</a>
			</div>
		</div>
		<div class="scroll-indicator">
			<div class="scroll-arrow"></div>
		</div>
	</section>

	<!-- Features Overview -->
	<section class="features-overview">
		<div class="container">
			<div class="feature-tags">
				<span class="tag tag-pvp">PvP</span>
				<span class="tag tag-pve">PvE</span>
				<span class="tag tag-mmo">MMO</span>
				<span class="tag tag-competitive">Competitive</span>
				<span class="tag tag-economy">Economy</span>
			</div>
		</div>
	</section>

	<!-- Gun Combat Section -->
	<section class="content-section section-guns">
		<div class="section-bg section-bg-guns"></div>
		<div class="container">
			<div class="section-header">
				<span class="section-number">01</span>
				<h2 class="section-title" data-i18n="gunsTitle">撃って、倒して、生き残れ。</h2>
				<p class="section-subtitle" data-i18n="gunsSubtitle">TaCZ - Tactical Combat Zone</p>
			</div>
			<div class="section-content">
				<div class="content-card">
					<div class="card-icon">🔫</div>
					<h3 data-i18n="taczTitle">TaCZ Gun Mod</h3>
					<p data-i18n="taczDesc">1.21.1対応の独自フォーク版。リアルな銃撃戦を実現。アドオンで拡張可能。</p>
				</div>
				<div class="content-card featured">
					<div class="card-icon">⚔</div>
					<h3 data-i18n="arenaTitle">TaCZArena</h3>
					<p data-i18n="arenaDesc">LoL「アリーナ」× Tarkov Arena。短時間・高密度の競技対戦。簡易ビルドシステム搭載。</p>
					<span class="card-badge" data-i18n="badgeDev">開発中</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Pokemon Section -->
	<section class="content-section section-pokemon">
		<div class="section-bg section-bg-pokemon"></div>
		<div class="container">
			<div class="section-header">
				<span class="section-number">02</span>
				<h2 class="section-title" data-i18n="pokemonTitle">捕まえて、育てて、戦え。</h2>
				<p class="section-subtitle">Cobblemon Ecosystem</p>
			</div>
			<div class="section-content section-content-3col">
				<div class="content-card">
					<div class="card-icon">🐉</div>
					<h3>Cobblemon</h3>
					<p data-i18n="cobblemonDesc">高品質ポケモンMod。ライド・料理など最新機能。</p>
				</div>
				<div class="content-card">
					<div class="card-icon">🏆</div>
					<h3>CobbleRanked</h3>
					<p data-i18n="rankedDesc">Eloベースのランクマッチ。カジュアル対戦も。</p>
					<span class="card-badge card-badge-done" data-i18n="badgeDone">実装済</span>
				</div>
				<div class="content-card">
					<div class="card-icon">🗺</div>
					<h3>CobbleDungeon</h3>
					<p data-i18n="dungeonDesc">「不思議のダンジョン」着想。ランダム生成インスタンス。</p>
					<span class="card-badge" data-i18n="badgeDev">開発中</span>
				</div>
				<div class="content-card">
					<div class="card-icon">🏰</div>
					<h3>CobbleGymWar</h3>
					<p data-i18n="gymwarDesc">ジムリーダーの座を巡る勢力争い。MMOギルド戦風。</p>
					<span class="card-badge card-badge-test" data-i18n="badgeTest">テスト中</span>
				</div>
				<div class="content-card">
					<div class="card-icon">🎯</div>
					<h3>CobbleCatchCombo</h3>
					<p data-i18n="comboDesc">Pokemon Let's GOの「コンボ捕獲」を再現。</p>
					<span class="card-badge card-badge-test" data-i18n="badgeTest">テスト中</span>
				</div>
				<div class="content-card">
					<div class="card-icon">💰</div>
					<h3>GashiMarket</h3>
					<p data-i18n="marketDesc">MMOライクなフリーマーケット・経済システム。</p>
					<span class="card-badge card-badge-test" data-i18n="badgeTest">テスト中</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Target Audience Section -->
	<section class="content-section section-target">
		<div class="container">
			<div class="section-header section-header-center">
				<h2 class="section-title" data-i18n="targetTitle">こんな人に刺さる。</h2>
			</div>
			<div class="target-grid">
				<div class="target-item">
					<span class="target-icon">🎮</span>
					<span data-i18n="target1">競技性が好き</span>
				</div>
				<div class="target-item">
					<span class="target-icon">⚔</span>
					<span data-i18n="target2">PvP / PvE両方楽しみたい</span>
				</div>
				<div class="target-item">
					<span class="target-icon">📈</span>
					<span data-i18n="target3">育成・ビルドが好き</span>
				</div>
				<div class="target-item">
					<span class="target-icon">💎</span>
					<span data-i18n="target4">経済要素が好き</span>
				</div>
				<div class="target-item">
					<span class="target-icon">⚡</span>
					<span data-i18n="target5">スピード感・中毒性重視</span>
				</div>
				<div class="target-item">
					<span class="target-icon">🌐</span>
					<span data-i18n="target6">MMO要素が好き</span>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="cta-section">
		<div class="container">
			<div class="cta-content">
				<p class="cta-date">2026.03</p>
				<h2 class="cta-title" data-i18n="ctaTitle">開発進行中</h2>
				<p class="cta-desc" data-i18n="ctaDesc">最新情報はDiscordで配信中。開発の裏側も公開しています。</p>
				<a href="https://discord.gg/VVVvBTqqyP" class="btn-primary btn-large" target="_blank">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
						<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
					</svg>
					<span data-i18n="ctaButton">Discordに参加する</span>
				</a>
			</div>
		</div>
	</section>

	<Footer />
	<LanguageSwitcher />

	<script is:inline>
	(function() {
		const translations = {
			en: {
				heroSubtitle: "COMING MARCH 2026",
				heroTitle1: "Everything Gamers Love,",
				heroTitle2: "All in One.",
				heroDesc: "Competitive play, MMO elements, PvP/PvE, builds, economy, speed and addiction.<br>A Minecraft server built with passion over a year.",
				ctaDiscord: "Get Updates on Discord",
				gunsTitle: "Shoot. Eliminate. Survive.",
				gunsSubtitle: "TaCZ - Tactical Combat Zone",
				taczTitle: "TaCZ Gun Mod",
				taczDesc: "Custom fork for 1.21.1. Realistic gunplay. Expandable with addons.",
				arenaTitle: "TaCZArena",
				arenaDesc: "LoL Arena × Tarkov Arena. Short, intense competitive matches. Simple build system.",
				pokemonTitle: "Catch. Train. Battle.",
				cobblemonDesc: "High-quality Pokemon mod. Latest features: riding, cooking.",
				rankedDesc: "ELO-based ranked matches. Casual mode available.",
				dungeonDesc: "Mystery Dungeon inspired. Random instance generation.",
				gymwarDesc: "Fight for Gym Leader status. MMO guild war style.",
				comboDesc: "Pokemon Let's GO catch combo system recreated.",
				marketDesc: "MMO-style freemarket economy system.",
				badgeDev: "In Development",
				badgeDone: "Ready",
				badgeTest: "Testing",
				targetTitle: "Perfect for you if...",
				target1: "You love competitive play",
				target2: "You enjoy both PvP & PvE",
				target3: "You love builds & progression",
				target4: "You enjoy economy systems",
				target5: "You crave speed & addiction",
				target6: "You love MMO elements",
				ctaTitle: "In Development",
				ctaDesc: "Follow development updates on Discord. Behind-the-scenes content available.",
				ctaButton: "Join Discord"
			},
			ja: {
				heroSubtitle: "2026年3月 公開予定",
				heroTitle1: "ゲーマーが好きな要素",
				heroTitle2: "全部入り。",
				heroDesc: "競技性、MMO、PvP/PvE、育成、経済、スピード感と中毒性。<br>1年以上かけて本気で作り込んだMinecraftサーバー。",
				ctaDiscord: "Discordで最新情報をチェック",
				gunsTitle: "撃って、倒して、生き残れ。",
				gunsSubtitle: "TaCZ - Tactical Combat Zone",
				taczTitle: "TaCZ Gun Mod",
				taczDesc: "1.21.1対応の独自フォーク版。リアルな銃撃戦を実現。アドオンで拡張可能。",
				arenaTitle: "TaCZArena",
				arenaDesc: "LoL「アリーナ」× Tarkov Arena。短時間・高密度の競技対戦。簡易ビルドシステム搭載。",
				pokemonTitle: "捕まえて、育てて、戦え。",
				cobblemonDesc: "高品質ポケモンMod。ライド・料理など最新機能。",
				rankedDesc: "Eloベースのランクマッチ。カジュアル対戦も。",
				dungeonDesc: "「不思議のダンジョン」着想。ランダム生成インスタンス。",
				gymwarDesc: "ジムリーダーの座を巡る勢力争い。MMOギルド戦風。",
				comboDesc: "Pokemon Let's GOの「コンボ捕獲」を再現。",
				marketDesc: "MMOライクなフリーマーケット・経済システム。",
				badgeDev: "開発中",
				badgeDone: "実装済",
				badgeTest: "テスト中",
				targetTitle: "こんな人に刺さる。",
				target1: "競技性が好き",
				target2: "PvP / PvE両方楽しみたい",
				target3: "育成・ビルドが好き",
				target4: "経済要素が好き",
				target5: "スピード感・中毒性重視",
				target6: "MMO要素が好き",
				ctaTitle: "開発進行中",
				ctaDesc: "最新情報はDiscordで配信中。開発の裏側も公開しています。",
				ctaButton: "Discordに参加する"
			}
		};

		function applyTranslations(lang) {
			const t = translations[lang] || translations.ja;
			document.querySelectorAll('[data-i18n]').forEach(el => {
				const key = el.getAttribute('data-i18n');
				if (t[key]) {
					if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
						el.placeholder = t[key];
					} else {
						el.innerHTML = t[key];
					}
				}
			});
		}

		function init() {
			const lang = window.GashiLang?.get() || 'ja';
			applyTranslations(lang);
		}

		window.addEventListener('langChange', (e) => {
			applyTranslations(e.detail.lang);
		});

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', init);
		} else {
			init();
		}

		// Intersection Observer for animations
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
				}
			});
		}, { threshold: 0.1 });

		document.querySelectorAll('.content-card, .section-header, .target-item').forEach(el => {
			observer.observe(el);
		});
	})();
	</script>

	<style is:global>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		html {
			scroll-behavior: smooth;
		}

		body {
			font-family: 'Inter', 'IBM Plex Mono', -apple-system, BlinkMacSystemFont, sans-serif;
			background: var(--bg-base);
			color: var(--text-primary);
			line-height: 1.6;
			overflow-x: clip;
		}

		.container {
			max-width: 1200px;
			margin: 0 auto;
			padding: 0 2rem;
		}

		/* Hero Section */
		.hero {
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			position: relative;
			overflow: hidden;
			padding-top: 80px;
		}

		.hero-bg {
			position: absolute;
			inset: 0;
			background:
				radial-gradient(ellipse at 50% 50%, rgba(139, 92, 246, 0.15) 0%, transparent 70%);
			z-index: 0;
		}

		.hero-particles {
			position: absolute;
			inset: 0;
			background-image:
				radial-gradient(2px 2px at 20px 30px, rgba(139, 92, 246, 0.15), transparent),
				radial-gradient(2px 2px at 40px 70px, rgba(139, 92, 246, 0.15), transparent),
				radial-gradient(1px 1px at 90px 40px, rgba(139, 92, 246, 0.15), transparent),
				radial-gradient(2px 2px at 130px 80px, rgba(139, 92, 246, 0.15), transparent),
				radial-gradient(1px 1px at 160px 120px, rgba(139, 92, 246, 0.15), transparent);
			background-size: 200px 200px;
			animation: particles 20s linear infinite;
			z-index: 0;
		}

		@keyframes particles {
			0% { transform: translateY(0); }
			100% { transform: translateY(-200px); }
		}

		.hero-content {
			position: relative;
			z-index: 1;
			text-align: center;
			padding: 2rem;
		}

		.hero-subtitle {
			font-size: 0.875rem;
			font-weight: 600;
			letter-spacing: 0.3em;
			color: var(--text-secondary);
			margin-bottom: 1.5rem;
			animation: fadeInUp 0.8s ease-out;
		}

		.hero-title {
			font-size: clamp(2.5rem, 8vw, 5rem);
			font-weight: 900;
			line-height: 1.1;
			margin-bottom: 1.5rem;
		}

		.hero-title-line {
			display: block;
			animation: fadeInUp 0.8s ease-out;
			animation-fill-mode: both;
		}

		.hero-title-line:nth-child(2) {
			animation-delay: 0.15s;
		}

		.hero-title-accent {
			background: #ffffff;
			-webkit-background-clip: initial;
			-webkit-text-fill-color: initial;
			background-clip: initial;
		}

		.hero-desc {
			font-size: 1.125rem;
			color: var(--text-secondary);
			max-width: 600px;
			margin: 0 auto 2.5rem;
			animation: fadeInUp 0.8s ease-out 0.3s both;
		}

		.hero-cta {
			animation: fadeInUp 0.8s ease-out 0.45s both;
		}

		@keyframes fadeInUp {
			from {
				opacity: 0;
				transform: translateY(30px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.btn-primary {
			display: inline-flex;
			align-items: center;
			gap: 0.75rem;
			background: transparent; border: 1px solid var(--border-strong);
			color: var(--text-primary);
			padding: 1rem 2rem;
			border-radius: 100vh;
			text-decoration: none;
			font-weight: 600;
			font-size: 1rem;
			transition: all 0.3s ease;
			border: none;
			cursor: pointer;
		}

		.btn-primary:hover {
			transform: translateY(-3px);
			background: #ffffff; color: #000000; border-color: #ffffff;
		}

		.btn-large {
			padding: 1.25rem 2.5rem;
			font-size: 1.125rem;
		}

		.scroll-indicator {
			position: absolute;
			bottom: 2rem;
			left: 50%;
			transform: translateX(-50%);
			animation: bounce 2s infinite;
		}

		.scroll-arrow {
			width: 24px;
			height: 24px;
			border-right: 2px solid var(--text-muted);
			border-bottom: 2px solid var(--text-muted);
			transform: rotate(45deg);
		}

		@keyframes bounce {
			0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
			40% { transform: translateX(-50%) translateY(10px); }
			60% { transform: translateX(-50%) translateY(5px); }
		}

		/* Features Overview */
		.features-overview {
			padding: 3rem 0;
			background: var(--color-bg);
		}

		.feature-tags {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: 1rem;
		}

		.tag {
			padding: 0.5rem 1.25rem;
			border-radius: 100px;
			font-size: 0.875rem;
			font-weight: 600;
			letter-spacing: 0.05em;
		}

		.tag-pvp { background: var(--bg-hover); color: var(--text-primary); border: 1px solid var(--border-subtle); }
		.tag-pve { background: var(--bg-hover); color: var(--text-secondary); border: 1px solid var(--border-subtle); }
		.tag-mmo { background: var(--bg-hover); color: var(--text-secondary); border: 1px solid var(--border-subtle); }
		.tag-competitive { background: var(--bg-hover); color: var(--text-secondary); border: 1px solid var(--border-subtle); }
		.tag-economy { background: var(--bg-hover); color: var(--text-secondary); border: 1px solid var(--border-subtle); }

		/* Content Sections */
		.content-section {
			padding: 6rem 0;
			position: relative;
			overflow: hidden;
		}

		.section-bg {
			position: absolute;
			inset: 0;
			z-index: 0;
		}

		.section-bg-guns {
			background:
				radial-gradient(ellipse at 0% 50%, rgba(139, 92, 246, 0.15) 0%, transparent 50%);
		}

		.section-bg-pokemon {
			background:
				radial-gradient(ellipse at 100% 50%, rgba(139, 92, 246, 0.15) 0%, transparent 50%);
		}

		.section-header {
			position: relative;
			z-index: 1;
			margin-bottom: 3rem;
			opacity: 0;
			transform: translateY(30px);
			transition: all 0.6s ease;
		}

		.section-header.visible {
			opacity: 1;
			transform: translateY(0);
		}

		.section-header-center {
			text-align: center;
		}

		.section-number {
			font-size: 0.875rem;
			font-weight: 700;
			color: var(--text-muted);
			letter-spacing: 0.2em;
			display: block;
			margin-bottom: 0.5rem;
		}

		.section-title {
			font-size: clamp(1.75rem, 5vw, 2.5rem);
			font-weight: 900;
			margin-bottom: 0.5rem;
		}

		.section-subtitle {
			font-size: 1rem;
			color: var(--text-muted);
			font-weight: 500;
		}

		.section-content {
			position: relative;
			z-index: 1;
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
			gap: 1.5rem;
		}

		.section-content-3col {
			grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		}

		.content-card {
			background: var(--bg-card);
			border: 1px solid var(--border-subtle);
			border-radius: 2px;
			padding: 2rem;
			position: relative;
			transition: all 0.4s ease;
			opacity: 0;
			transform: translateY(30px);
		}

		.content-card.visible {
			opacity: 1;
			transform: translateY(0);
		}

		.content-card:hover {
			background: var(--bg-hover);
			border-color: var(--border-strong);
			transform: translateY(-5px);
		}

		.content-card.featured {
			background: var(--bg-hover);
			border-color: rgba(167, 139, 250, 0.3);
		}

		.card-icon {
			font-size: 2.5rem;
			margin-bottom: 1rem;
		}

		.content-card h3 {
			font-size: 1.25rem;
			font-weight: 700;
			margin-bottom: 0.75rem;
		}

		.content-card p {
			font-size: 0.9375rem;
			color: var(--text-secondary);
			line-height: 1.7;
		}

		.card-badge {
			display: inline-block;
			margin-top: 1rem;
			padding: 0.25rem 0.75rem;
			background: var(--purple-100);
			color: var(--text-secondary);
			border-radius: 100px;
			font-size: 0.75rem;
			font-weight: 600;
		}

		.card-badge-done {
			background: var(--purple-100);
			color: var(--text-primary);
		}

		.card-badge-test {
			background: var(--bg-hover);
			color: var(--text-secondary);
		}

		/* Target Section */
		.section-target {
			background: var(--color-bg-alt);
		}

		.target-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
			gap: 1rem;
		}

		.target-item {
			display: flex;
			align-items: center;
			gap: 1rem;
			padding: 1.25rem 1.5rem;
			background: var(--bg-card);
			border: 1px solid var(--border-subtle);
			border-radius: 12px;
			transition: all 0.3s ease;
			opacity: 0;
			transform: translateY(20px);
		}

		.target-item.visible {
			opacity: 1;
			transform: translateY(0);
		}

		.target-item:hover {
			background: var(--bg-hover);
			border-color: rgba(167, 139, 250, 0.3);
		}

		.target-icon {
			font-size: 1.5rem;
		}

		.target-item span:last-child {
			font-weight: 500;
			font-size: 0.9375rem;
		}

		/* CTA Section */
		.cta-section {
			padding: 8rem 0;
			background:
				radial-gradient(ellipse at 50% 100%, rgba(139, 92, 246, 0.15) 0%, transparent 60%);
		}

		.cta-content {
			text-align: center;
		}

		.cta-date {
			font-size: 3rem;
			font-weight: 900;
			background: var(--gradient-brand);
			-webkit-background-clip: initial;
			-webkit-text-fill-color: initial;
			background-clip: initial;
			margin-bottom: 0.5rem;
		}

		.cta-title {
			font-size: 2rem;
			font-weight: 700;
			margin-bottom: 1rem;
		}

		.cta-desc {
			font-size: 1.125rem;
			color: var(--text-secondary);
			margin-bottom: 2rem;
		}

		/* Responsive */
		@media (max-width: 768px) {
			.hero-title {
				font-size: 2.5rem;
			}

			.hero-desc {
				font-size: 1rem;
			}

			.content-section {
				padding: 4rem 0;
			}

			.section-content {
				grid-template-columns: 1fr;
			}

			.target-grid {
				grid-template-columns: 1fr;
			}

			.cta-date {
				font-size: 2.5rem;
			}
		}

		/* Animation delays for cards */
		.content-card:nth-child(1) { transition-delay: 0s; }
		.content-card:nth-child(2) { transition-delay: 0.1s; }
		.content-card:nth-child(3) { transition-delay: 0.2s; }
		.content-card:nth-child(4) { transition-delay: 0.3s; }
		.content-card:nth-child(5) { transition-delay: 0.4s; }
		.content-card:nth-child(6) { transition-delay: 0.5s; }

		.target-item:nth-child(1) { transition-delay: 0s; }
		.target-item:nth-child(2) { transition-delay: 0.05s; }
		.target-item:nth-child(3) { transition-delay: 0.1s; }
		.target-item:nth-child(4) { transition-delay: 0.15s; }
		.target-item:nth-child(5) { transition-delay: 0.2s; }
		.target-item:nth-child(6) { transition-delay: 0.25s; }

		/* ===== Warped Grid Background ===== */
		.warped-grid {
			position: fixed;
			inset: 0;
			z-index: 0;
			pointer-events: none;
			perspective: 800px;
			display: flex;
			align-items: center;
			justify-content: center;
			overflow: hidden;
		}

		.warped-grid-inner {
			width: 120%;
			height: 120%;
			background-image:
				repeating-linear-gradient(0deg, rgba(26, 26, 26, 0.04) 0, rgba(26, 26, 26, 0.04) 1px, transparent 1px, transparent 64px),
				repeating-linear-gradient(90deg, rgba(26, 26, 26, 0.04) 0, rgba(26, 26, 26, 0.04) 1px, transparent 1px, transparent 64px);
			animation: gridWarp 12s ease-in-out infinite;
		}

		@keyframes gridWarp {
			0%, 100% { transform: perspective(800px) rotateX(0deg) rotateY(0deg); }
			25% { transform: perspective(800px) rotateX(0.3deg) rotateY(-0.3deg); }
			50% { transform: perspective(800px) rotateX(-0.3deg) rotateY(0.3deg); }
			75% { transform: perspective(800px) rotateX(0.2deg) rotateY(0.2deg); }
		}

		/* ===== Viewport Frame ===== */
		.viewport-frame {
			position: fixed;
			inset: 8px;
			z-index: 9999;
			pointer-events: none;
		}

	</style>

	<!-- Warped grid background -->
	<div class="warped-grid" aria-hidden="true">
		<div class="warped-grid-inner"></div>
	</div>

	<!-- Viewport frame -->
	<svg class="viewport-frame" viewBox="0 0 100 100" preserveAspectRatio="none">
		<rect x="0.4" y="0.4" width="99.2" height="99.2" rx="0.6" ry="0.6"
			fill="none" stroke="rgba(139, 92, 246, 0.1)" stroke-width="0.12" vector-effect="non-scaling-stroke"/>
	</svg>
</body>
</html>
