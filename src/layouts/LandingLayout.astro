---
import CustomNav from '../components/CustomNav.astro';
import HeroSection from '../components/HeroSection.astro';
import ProductsSection from '../components/ProductsSection.astro';
import ShowcaseSection from '../components/ShowcaseSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import ProfileSection from '../components/ProfileSection.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;
const siteUrl = 'https://gashistudios.site';
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
const metaDescription = description || 'GashiStudios - A community creating high-quality Mods for Cobblemon';

// Static OG image (logo)
const ogImage = `${siteUrl}/gashistudios.png`;
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/png" href="/gashistudios.png" />
	<meta name="description" content={metaDescription} />
	<title>{title}</title>

	<!-- Open Graph / Discord Embed -->
	<meta property="og:type" content="website" />
	<meta property="og:url" content={pageUrl} />
	<meta property="og:title" content={title} />
	<meta property="og:description" content={metaDescription} />
	<meta property="og:image" content={ogImage} />
	<meta property="og:site_name" content="GashiStudios" />

	<!-- Twitter Card (summary = small thumbnail on left) -->
	<meta name="twitter:card" content="summary" />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={metaDescription} />
	<meta name="twitter:image" content={ogImage} />

	<!-- Theme Color (Discord embed sidebar) -->
	<meta name="theme-color" content="#0a0a0f" />
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=Libre+Barcode+128&display=swap" rel="stylesheet">
	<style is:global>
		/* ===== CSS Custom Properties - B&W Theme ===== */
		:root {
			--color-bg: #0a0a0f;
			--color-bg-alt: #111118;
			--color-bg-card: #16161e;
			--color-text: #e4e4e7;
			--color-text-muted: #a1a1aa;
			--color-primary: #ffffff;
			--color-border: rgba(255, 255, 255, 0.1);
			--color-accent: #ffffff;

			/* Grid system */
			--grid-line: rgba(255, 255, 255, 0.06);
			--grid-line-strong: rgba(255, 255, 255, 0.12);

			/* Surface */
			--color-surface: #111;
			--color-surface-hover: #1a1a1a;
		}

		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		html {
			scroll-behavior: smooth;
		}

		body {
			font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
			background: var(--color-bg);
			color: var(--color-text);
			line-height: 1.6;
			overflow-x: clip;
		}

		a {
			color: inherit;
		}

		img {
			max-width: 100%;
			height: auto;
			user-select: none;
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;
			-webkit-user-drag: none;
			-webkit-touch-callout: none;
			pointer-events: none;
			cursor: default;
		}

		/* Allow pointer events on clickable images (inside links) */
		a img, button img {
			pointer-events: auto;
		}

		/* Disable text selection cursor on clickable elements */
		button, a, .product-card, .submit-btn {
			user-select: none;
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;
			cursor: pointer;
		}

		svg {
			user-select: none;
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;
			-webkit-user-drag: none;
			pointer-events: none;
			cursor: default;
		}

		/* Allow pointer events on clickable SVGs (inside links/buttons) */
		a svg, button svg {
			pointer-events: auto;
		}

		/* Prevent selection highlight on images and decorative elements */
		img::selection,
		svg::selection {
			background: transparent;
		}

		/* ===== Keyframe Animations ===== */
		@keyframes fadeIn {
			from { opacity: 0; }
			to { opacity: 1; }
		}

		@keyframes fadeInUp {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}

		@keyframes marquee {
			from { transform: translateX(0); }
			to { transform: translateX(-50%); }
		}

		@keyframes bounceIn {
			0% { transform: scale(0.3); opacity: 0; }
			50% { transform: scale(1.05); }
			70% { transform: scale(0.95); }
			100% { transform: scale(1); opacity: 1; }
		}

		@keyframes fadeInStagger {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}

		@keyframes gridWarp {
			0%, 100% { transform: perspective(800px) rotateX(0deg) rotateY(0deg); }
			25% { transform: perspective(800px) rotateX(0.3deg) rotateY(-0.3deg); }
			50% { transform: perspective(800px) rotateX(-0.3deg) rotateY(0.3deg); }
			75% { transform: perspective(800px) rotateX(0.2deg) rotateY(0.2deg); }
		}

		@keyframes scrollBounce {
			0%, 100% { transform: translateY(0); }
			50% { transform: translateY(6px); }
		}

		/* ===== Utility Classes ===== */

		/* Marquee */
		.marquee-track {
			overflow: hidden;
			white-space: nowrap;
		}

		.marquee-content {
			display: inline-flex;
			animation: marquee 20s linear infinite;
		}

		.marquee-content:hover {
			animation-play-state: paused;
		}

		/* Grid line background */
		.bg-grid {
			background-image:
				repeating-linear-gradient(0deg, var(--grid-line) 0, var(--grid-line) 1px, transparent 1px, transparent 48px),
				repeating-linear-gradient(90deg, var(--grid-line) 0, var(--grid-line) 1px, transparent 1px, transparent 48px);
		}

				/* ===== Dialog Window Card System ===== */
		.window-card {
			background: var(--color-surface);
			border: solid 1px rgba(255, 255, 255, 0.12);
			border-radius: 2px;
			overflow: hidden;
			transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
		}

		.window-card:hover {
			border-color: rgba(255, 255, 255, 0.25);
			transform: translateY(-4px);
			box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
		}

		.window-titlebar {
			display: flex;
			align-items: center;
			justify-content: space-between;
			height: 2rem;
			padding: 0 0.5rem 1px 0.625rem;
			background: var(--color-bg);
			border-bottom: solid 1px rgba(255, 255, 255, 0.08);
			cursor: grab;
		}

		.window-title {
			font-size: 0.75rem;
			color: rgba(255, 255, 255, 0.4);
			font-family: "IBM Plex Mono", monospace;
			letter-spacing: 0.02em;
			pointer-events: none;
		}

		.window-close {
			width: 1.125rem;
			height: 1.125rem;
			position: relative;
			flex-shrink: 0;
			pointer-events: none;
		}

		.window-close::before,
		.window-close::after {
			content: '';
			position: absolute;
			top: 50%;
			left: 50%;
			width: 60%;
			height: 1px;
			background: rgba(255, 255, 255, 0.3);
		}

		.window-close::before {
			transform: translate(-50%, -50%) rotate(45deg);
		}

		.window-close::after {
			transform: translate(-50%, -50%) rotate(-45deg);
		}

		.window-content {
			padding: 1.25rem;
		}

		/* Outer page frame */
		.page-frame {
			position: fixed;
			top: 0;
			left: 0;
			width: 100vw;
			height: 100svh;
			pointer-events: none;
			z-index: 2000;
		}

/* Main container */
		main {
			position: relative;
		}

		/* Sections container */
		.seamless-sections {
			position: relative;
			background: var(--color-bg);
			z-index: 1;
		}

		/* Selection Color */
		::selection {
			background: rgba(255, 255, 255, 0.2);
			color: var(--color-text);
		}

		/* Custom Scrollbar */
		::-webkit-scrollbar {
			width: 8px;
			height: 8px;
		}

		::-webkit-scrollbar-track {
			background: var(--color-bg);
		}

		::-webkit-scrollbar-thumb {
			background: rgba(255, 255, 255, 0.2);
			border-radius: 4px;
		}

		::-webkit-scrollbar-thumb:hover {
			background: rgba(255, 255, 255, 0.3);
		}

		/* ===== Loading Screen ===== */
		.loading-screen {
			position: fixed;
			inset: 0;
			z-index: 99999;
			background: var(--color-bg);
			display: flex;
			align-items: center;
			justify-content: center;
			transition: opacity 0.4s ease, visibility 0.4s ease;
		}

		.loading-screen.hidden {
			opacity: 0;
			visibility: hidden;
		}

		.loading-content {
			text-align: center;
		}

		.loading-counter {
			font-size: 4rem;
			font-weight: 800;
			color: #ffffff;
			font-family: 'IBM Plex Mono', monospace;
			font-variant-numeric: tabular-nums;
			line-height: 1;
		}

		.loading-text {
			font-size: 0.85rem;
			color: var(--color-text-muted);
			text-transform: uppercase;
			letter-spacing: 0.15em;
			margin-top: 0.5rem;
			font-family: 'IBM Plex Mono', monospace;
		}

		/* ===== Marquee Divider ===== */
		.marquee-divider {
			background: var(--color-surface);
			border-top: 1px solid var(--grid-line-strong);
			border-bottom: 1px solid var(--grid-line-strong);
			padding: 0.875rem 0;
			overflow: hidden;
			position: relative;
			z-index: 2;
		}

		.marquee-divider .marquee-content {
			animation: marquee 18s linear infinite;
		}

		.marquee-item {
			display: inline-flex;
			align-items: center;
			gap: 1.5rem;
			color: rgba(255, 255, 255, 0.5);
			font-size: 0.85rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			padding: 0 1.5rem;
			white-space: nowrap;
			font-family: 'IBM Plex Mono', monospace;
		}

		.marquee-item .item-dot {
			width: 4px;
			height: 4px;
			background: rgba(255,255,255,0.3);
			border-radius: 50%;
			flex-shrink: 0;
		}

		/* ===== Reduced Motion ===== */
		@media (prefers-reduced-motion: reduce) {
			*, *::before, *::after {
				animation-duration: 0.01ms !important;
				animation-iteration-count: 1 !important;
				transition-duration: 0.01ms !important;
			}
		}

			/* ===== Warped Grid Background ===== */
			.warped-grid {
				position: fixed;
				inset: 0;
				z-index: 0;
				pointer-events: none;
				perspective: 800px;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
			}

			.warped-grid-inner {
				width: 120%;
				height: 120%;
				background-image:
					repeating-linear-gradient(0deg, rgba(255,255,255,0.04) 0, rgba(255,255,255,0.04) 1px, transparent 1px, transparent 64px),
					repeating-linear-gradient(90deg, rgba(255,255,255,0.04) 0, rgba(255,255,255,0.04) 1px, transparent 1px, transparent 64px);
				animation: gridWarp 12s ease-in-out infinite;
			}

			/* ===== Viewport Frame ===== */
			.viewport-frame {
				position: fixed;
				inset: 8px;
				z-index: 9999;
				pointer-events: none;
			}

	</style>
</head>
<body>
	<!-- Loading Screen -->
	<div id="loadingScreen" class="loading-screen">
		<div class="loading-content">
			<div class="loading-counter"><span id="loadingPercent">0</span>%</div>
			<p class="loading-text">loading...</p>
		</div>
	</div>

	<CustomNav />
	<main>
		<HeroSection />

		<!-- Marquee Divider -->
		<div class="marquee-divider">
			<div class="marquee-track">
				<div class="marquee-content">
					<span class="marquee-item"><span class="item-dot"></span>JAVA</span>
					<span class="marquee-item"><span class="item-dot"></span>KOTLIN</span>
					<span class="marquee-item"><span class="item-dot"></span>TYPESCRIPT</span>
					<span class="marquee-item"><span class="item-dot"></span>DOCKER</span>
					<span class="marquee-item"><span class="item-dot"></span>FIREBASE</span>
					<span class="marquee-item"><span class="item-dot"></span>MYSQL</span>
					<span class="marquee-item"><span class="item-dot"></span>REDIS</span>
					<span class="marquee-item"><span class="item-dot"></span>FIGMA</span>
					<span class="marquee-item"><span class="item-dot"></span>INTELLIJ</span>
					<span class="marquee-item"><span class="item-dot"></span>GIT</span>
					<span class="marquee-item"><span class="item-dot"></span>JAVA</span>
					<span class="marquee-item"><span class="item-dot"></span>KOTLIN</span>
					<span class="marquee-item"><span class="item-dot"></span>TYPESCRIPT</span>
					<span class="marquee-item"><span class="item-dot"></span>DOCKER</span>
					<span class="marquee-item"><span class="item-dot"></span>FIREBASE</span>
					<span class="marquee-item"><span class="item-dot"></span>MYSQL</span>
					<span class="marquee-item"><span class="item-dot"></span>REDIS</span>
					<span class="marquee-item"><span class="item-dot"></span>FIGMA</span>
					<span class="marquee-item"><span class="item-dot"></span>INTELLIJ</span>
					<span class="marquee-item"><span class="item-dot"></span>GIT</span>
				</div>
			</div>
		</div>

		<div class="seamless-sections">
			<ProductsSection />
			<ShowcaseSection />
			<TestimonialsSection />
			<ProfileSection />
			<ContactSection />
		</div>
	</main>
	<Footer />
	<LanguageSwitcher />


		<!-- Warped grid background -->
		<div class="warped-grid" aria-hidden="true">
			<div class="warped-grid-inner"></div>
		</div>

		<!-- Viewport frame -->
		<svg class="viewport-frame" viewBox="0 0 100 100" preserveAspectRatio="none">
			<rect x="0.4" y="0.4" width="99.2" height="99.2" rx="0.6" ry="0.6"
				fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="0.12" vector-effect="non-scaling-stroke"/>
		</svg>

	<script is:inline>
		// Loading screen animation
		(function() {
			const counter = document.getElementById('loadingPercent');
			const screen = document.getElementById('loadingScreen');
			let current = 0;

			function tick() {
				const step = Math.floor(Math.random() * 12) + 3;
				current = Math.min(current + step, 100);
				if (counter) counter.textContent = current;

				if (current < 100) {
					setTimeout(tick, 60 + Math.random() * 40);
				} else {
					setTimeout(() => {
						if (screen) screen.classList.add('hidden');
					}, 250);
				}
			}

			tick();
		})();
	</script>
</body>
</html>
