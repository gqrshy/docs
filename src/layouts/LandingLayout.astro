---
import '../styles/tokens.css';
import '../styles/motion.css';
import '@phosphor-icons/web/regular';
import '@phosphor-icons/web/bold';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import CartDrawer from '../components/CartDrawer.astro';
import CatalogSection from '../components/CatalogSection.astro';
import CustomNav from '../components/CustomNav.astro';
import HeroSection from '../components/HeroSection.astro';
import WhatWeDoSection from '../components/WhatWeDoSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import ProductsSection from '../components/ProductsSection.astro';
import ShowcaseSection from '../components/ShowcaseSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import TeamSection from '../components/TeamSection.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;
const siteUrl = 'https://gashistudios.site';
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
const metaDescription = description || 'GashiStudios - Minecraft mod & server plugin development team';

// Static OG image (logo)
const ogImage = `${siteUrl}/gashistudios.png`;
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/png" href="/gashistudios.png" />
	<meta name="description" content={metaDescription} />
	<title>{title}</title>

	<!-- Open Graph / Discord Embed -->
	<meta property="og:type" content="website" />
	<meta property="og:url" content={pageUrl} />
	<meta property="og:title" content={title} />
	<meta property="og:description" content={metaDescription} />
	<meta property="og:image" content={ogImage} />
	<meta property="og:site_name" content="GashiStudios" />

	<!-- Twitter Card (summary = small thumbnail on left) -->
	<meta name="twitter:card" content="summary" />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={metaDescription} />
	<meta name="twitter:image" content={ogImage} />

	<!-- Theme Color (Discord embed sidebar) -->
	<meta name="theme-color" content="#fafafa" />
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
	<style is:global>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		html {
			scroll-behavior: smooth;
		}

		body {
			font-family: var(--font-sans);
			background: var(--bg-base);
			color: var(--text-primary);
			line-height: 1.6;
			overflow-x: clip;
		}

		h1, h2, h3, h4 {
			font-family: var(--font-display);
		}

		a {
			color: inherit;
		}

		img {
			max-width: 100%;
			height: auto;
			user-select: none;
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;
			-webkit-user-drag: none;
			-webkit-touch-callout: none;
			pointer-events: none;
			cursor: default;
		}

		/* Allow pointer events on clickable images (inside links) */
		a img, button img {
			pointer-events: auto;
		}

		/* Disable text selection cursor on clickable elements */
		button, a, .product-card, .submit-btn {
			user-select: none;
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;
			cursor: pointer;
		}

		svg {
			user-select: none;
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;
			-webkit-user-drag: none;
			pointer-events: none;
			cursor: default;
		}

		/* Allow pointer events on clickable SVGs (inside links/buttons) */
		a svg, button svg {
			pointer-events: auto;
		}

		/* Prevent selection highlight on images and decorative elements */
		img::selection,
		svg::selection {
			background: transparent;
		}

		/* ===== Keyframe Animations ===== */
		@keyframes fadeIn {
			from { opacity: 0; }
			to { opacity: 1; }
		}

		@keyframes fadeInUp {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}

		@keyframes bounceIn {
			0% { transform: scale(0.3); opacity: 0; }
			50% { transform: scale(1.05); }
			70% { transform: scale(0.95); }
			100% { transform: scale(1); opacity: 1; }
		}

		@keyframes fadeInStagger {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}

		@keyframes scrollBounce {
			0%, 100% { transform: translateY(0); }
			50% { transform: translateY(6px); }
		}

		/* ===== Window Card (legacy — replaced by rounded cards in Phase 2) ===== */
		.window-card {
			background: var(--bg-card);
			border: solid 1px var(--border-subtle);
			border-radius: 12px;
			overflow: hidden;
			transition: border-color var(--dur-base) var(--ease-out-expo),
				transform var(--dur-base) var(--ease-bounce),
				box-shadow var(--dur-base) var(--ease-out-expo);
		}

		.window-card:hover {
			border-color: var(--border-strong);
			transform: translateY(-4px);
			box-shadow: var(--shadow-card-hover);
		}

		.window-titlebar {
			display: flex;
			align-items: center;
			justify-content: space-between;
			height: 2rem;
			padding: 0 0.5rem 1px 0.625rem;
			background: var(--bg-base);
			border-bottom: solid 1px var(--border-subtle);
			cursor: grab;
		}

		.window-title {
			font-size: 0.75rem;
			color: var(--text-muted);
			font-family: var(--font-mono);
			letter-spacing: 0.02em;
			pointer-events: none;
		}

		.window-close {
			width: 1.125rem;
			height: 1.125rem;
			position: relative;
			flex-shrink: 0;
			pointer-events: none;
		}

		.window-close::before,
		.window-close::after {
			content: '';
			position: absolute;
			top: 50%;
			left: 50%;
			width: 60%;
			height: 1px;
			background: var(--text-muted);
		}

		.window-close::before {
			transform: translate(-50%, -50%) rotate(45deg);
		}

		.window-close::after {
			transform: translate(-50%, -50%) rotate(-45deg);
		}

		.window-content {
			padding: 1.25rem;
		}

		/* ===== Buttons (REDESIGN.md §7 — pill shape) ===== */
		.btn {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.75rem 1.75rem;
			border-radius: var(--radius-btn);
			font-size: 0.9rem;
			font-weight: 600;
			text-decoration: none;
			border: none;
			transition: transform var(--dur-base) var(--ease-bounce),
				filter var(--dur-base) var(--ease-out-expo),
				background var(--dur-base) var(--ease-out-expo),
				border-color var(--dur-base) var(--ease-out-expo);
		}

		.btn:hover {
			transform: scale(1.05);
		}

		.btn:active {
			transform: scale(0.96);
			transition-duration: var(--dur-fast);
		}

		.btn-primary {
			background: var(--gradient-brand);
			color: #ffffff;
		}

		.btn-primary:hover {
			filter: brightness(1.2);
		}

		.btn-secondary {
			background: var(--bg-card);
			border: 1px solid var(--border-strong);
			color: var(--text-accent);
		}

		.btn-secondary:hover {
			background: var(--purple-100);
		}

		/* ===== Section headers ===== */
		.section-label {
			display: block;
			font-family: var(--font-mono);
			font-size: 0.8rem;
			font-weight: 500;
			color: var(--text-accent);
			letter-spacing: 0.12em;
			text-transform: uppercase;
			margin-bottom: 0.75rem;
		}

		.section-heading {
			font-family: var(--font-display);
			font-size: 2rem;
			font-weight: 700;
			color: var(--text-primary);
			letter-spacing: -0.02em;
			margin-bottom: 0.5rem;
		}

		.section-lead {
			font-size: 1rem;
			color: var(--text-secondary);
			margin-bottom: 2.5rem;
		}

		/* ===== Platform badges (REDESIGN.md §7) ===== */
		.badge {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			padding: 0.25rem 0.75rem;
			border-radius: var(--radius-btn);
			background: var(--bg-hover);
			color: var(--text-secondary);
			font-family: var(--font-mono);
			font-size: 0.7rem;
			font-weight: 500;
			white-space: nowrap;
		}

		.badge::before {
			content: '';
			width: 6px;
			height: 6px;
			border-radius: 50%;
			background: var(--text-muted);
			flex-shrink: 0;
		}

		.badge-mod::before { background: var(--purple-400); }
		.badge-plugin::before { background: var(--accent-lime); }
		.badge-lib::before { background: var(--text-muted); }

		/* Main container */
		main {
			position: relative;
		}

		/* Sections container */
		.seamless-sections {
			position: relative;
			background: var(--bg-base);
			z-index: 1;
		}

		/* Selection Color */
		::selection {
			background: var(--purple-200);
			color: var(--text-primary);
		}

		/* Custom Scrollbar */
		::-webkit-scrollbar {
			width: 8px;
			height: 8px;
		}

		::-webkit-scrollbar-track {
			background: var(--bg-base);
		}

		::-webkit-scrollbar-thumb {
			background: var(--purple-300);
			border-radius: 4px;
		}

		::-webkit-scrollbar-thumb:hover {
			background: var(--purple-400);
		}

		/* ===== Reduced Motion ===== */
		@media (prefers-reduced-motion: reduce) {
			*, *::before, *::after {
				animation-duration: 0.01ms !important;
				animation-iteration-count: 1 !important;
				transition-duration: 0.01ms !important;
			}
		}
	</style>
</head>
<body>
	<AnnouncementBar />
	<CustomNav />
	<main>
		<HeroSection />

		<div class="seamless-sections">
			<ProductsSection />
			<CatalogSection />
			<WhatWeDoSection />
			<ProjectsSection />
			<ShowcaseSection />
			<TestimonialsSection />
			<TeamSection />
			<ContactSection />
		</div>
	</main>
	<Footer />
	<CartDrawer />
	<LanguageSwitcher />

	<script is:inline>
		// Scroll-entrance animations: adds .is-visible once per element
		// (utility classes defined in styles/motion.css)
		(function() {
			const targets = document.querySelectorAll('.reveal-up, .reveal-clip, .pop-in, .stagger-children, .curtain-reveal');
			if (!targets.length) return;

			if (!('IntersectionObserver' in window)) {
				targets.forEach(el => el.classList.add('is-visible'));
				return;
			}

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('is-visible');
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

			targets.forEach(el => observer.observe(el));
		})();
	</script>
</body>
</html>
